{
  "run": {
    "industry": "Apparel Retail",
    "sourceType": "ECOM",
    "defaultTimeZoneId": "Eastern Standard Time",
    "foundry": {
      "endpoint": "https://my-foundry.services.ai.azure.com",
      "deployment": "gpt-4.1",
      "authMethod": "ManagedIdentity"
    },
    "locale": "en-US"
  },
  "entities": [
    {
      "schemaArea": "core",
      "entityName": "Account",
      "mode": "RealTime",
      "schedule": {
        "split": "WeekdayWeekend",
        "weekday": {
          "morning": 1.0,
          "afternoon": 1.4,
          "evening": 0.8,
          "night": 0.1
        },
        "weekend": {
          "morning": 0.6,
          "afternoon": 0.9,
          "evening": 1.2,
          "night": 0.2
        }
      },
      "realtime": {
        "perHour": {
          "new": 120,
          "update": 40,
          "delete": 5
        }
      },
      "boosts": [
        {
          "date": "2026-08-15",
          "boostPercent": 25,
          "daysBefore": 14,
          "daysAfter": 6,
          "boostPercentOnDate": 50
        }
      ]
    },
    {
      "schemaArea": "core",
      "entityName": "RetailTransactionTable",
      "mode": "Batch",
      "schedule": {
        "split": "WholeWeek",
        "week": {
          "morning": 1.0,
          "afternoon": 1.0,
          "evening": 1.0,
          "night": 0.3
        }
      },
      "batch": {
        "frequency": {
          "count": 4,
          "per": "Day"
        },
        "perBatch": {
          "new": 5000,
          "update": 1500,
          "delete": 100
        }
      },
      "boosts": [],
      "locale": "es-MX"
    }
  ],
  "targets": [
    {
      "targetType": "JsonFile",
      "name": "local-ndjson",
      "enabled": true,
      "authentication": {
        "method": "None"
      },
      "properties": {
        "directory": "./out"
      }
    },
    {
      "targetType": "ADLSGen2",
      "name": "adls-raw",
      "enabled": false,
      "authentication": {
        "method": "ManagedIdentity"
      },
      "properties": {
        "accountName": "mydatalake",
        "endpoint": "https://mydatalake.dfs.core.windows.net",
        "filesystem": "raw",
        "directory": "datagen"
      }
    },
    {
      "targetType": "ADLSGen2Parquet",
      "name": "adls-curated",
      "enabled": false,
      "authentication": {
        "method": "ManagedIdentity"
      },
      "properties": {
        "accountName": "mydatalake",
        "endpoint": "https://mydatalake.dfs.core.windows.net",
        "filesystem": "curated",
        "directory": "datagen"
      }
    },
    {
      "targetType": "AzureSqlDB",
      "name": "sqldb-prod",
      "enabled": false,
      "authentication": {
        "method": "ManagedIdentity"
      },
      "properties": {
        "server": "mysrv.database.windows.net",
        "database": "sales",
        "schema": "dbo",
        "table": "Account"
      }
    },
    {
      "targetType": "EventHubs",
      "name": "eventhub-stream",
      "enabled": false,
      "authentication": {
        "method": "ManagedIdentity"
      },
      "properties": {
        "namespace": "my-eventhubs-ns",
        "eventHub": "datagen-events",
        "partitionKeyField": "accountId",
        "consumerGroup": "$Default"
      }
    }
  ]
}
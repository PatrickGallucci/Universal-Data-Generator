using System.Text.Json;
using DataGen.Abstractions;
using DataGen.Targets;
using Xunit;

namespace DataGen.Targets.Tests;

public class NdjsonFormatterTests
{
    [Fact]
    public void Record_envelope_carries_action_key_and_fields()
    {
        var record = new GeneratedRecord
        {
            Action = RecordAction.Update,
            Key = Guid.Parse("11111111-1111-1111-1111-111111111111"),
            Fields = new Dictionary<string, object?> { ["name"] = "Acme", ["amount"] = 42 }
        };

        string line = NdjsonFormatter.SerializeRecord(record, new DateTimeOffset(2026, 8, 15, 10, 0, 0, TimeSpan.Zero));
        using JsonDocument doc = JsonDocument.Parse(line);

        Assert.Equal("Update", doc.RootElement.GetProperty("_action").GetString());
        Assert.Equal("11111111-1111-1111-1111-111111111111", doc.RootElement.GetProperty("_key").GetString());
        Assert.Equal("Acme", doc.RootElement.GetProperty("name").GetString());
        Assert.Equal(42, doc.RootElement.GetProperty("amount").GetInt32());
    }

    [Fact]
    public void Serialize_emits_one_line_per_record()
    {
        var batch = new EntityBatch
        {
            SchemaArea = "core",
            EntityName = "Account",
            GeneratedAt = DateTimeOffset.UtcNow,
            Records =
            [
                new GeneratedRecord { Action = RecordAction.New, Key = 1, Fields = new Dictionary<string, object?>() },
                new GeneratedRecord { Action = RecordAction.New, Key = 2, Fields = new Dictionary<string, object?>() }
            ]
        };

        string[] lines = NdjsonFormatter.Serialize(batch).Split('\n', StringSplitOptions.RemoveEmptyEntries);
        Assert.Equal(2, lines.Length);
    }
}

public class AdlsPathTests
{
    private static readonly DateTimeOffset At = new(2026, 8, 15, 10, 0, 0, TimeSpan.Zero);

    [Fact]
    public void Directory_is_hive_partitioned()
        => Assert.Equal("raw/core/Account/2026/08/15", AdlsPath.BuildDirectory("raw", "core", "Account", At));

    [Fact]
    public void Directory_without_base_omits_leading_segment()
        => Assert.Equal("core/Account/2026/08/15", AdlsPath.BuildDirectory(null, "core", "Account", At));

    [Fact]
    public void Directory_trims_slashes_on_base()
        => Assert.Equal("raw/zone/core/Account/2026/08/15", AdlsPath.BuildDirectory("/raw/zone/", "core", "Account", At));

    [Fact]
    public void File_name_is_prefixed_and_ndjson()
    {
        string name = AdlsPath.BuildFileName("Account", At);
        Assert.StartsWith("Account-20260815100000000", name);
        Assert.EndsWith(".ndjson", name);
    }
}

public class SinkFactoryTests
{
    private static TargetConfig Adls() => new()
    {
        TargetType = "ADLSGen2",
        Name = "adls",
        Properties = new Dictionary<string, object?> { ["accountName"] = "acct", ["filesystem"] = "raw", ["directory"] = "zone" }
    };

    [Fact]
    public void Factory_creates_real_adls_sink()
    {
        var factory = new SinkFactory();
        Assert.True(factory.CanCreate("ADLSGen2"));
        Assert.IsType<AdlsGen2Sink>(factory.Create(Adls()));
    }

    [Fact]
    public void Adls_sink_resolves_account_from_endpoint()
    {
        var config = new TargetConfig
        {
            TargetType = "ADLSGen2",
            Name = "adls",
            Properties = new Dictionary<string, object?> { ["endpoint"] = "https://myacct.dfs.core.windows.net", ["container"] = "raw" }
        };

        // Construction succeeds (account resolved from endpoint, filesystem from container).
        var sink = new AdlsGen2Sink(config);
        Assert.Equal("ADLSGen2", sink.TargetType);
        Assert.Equal(SinkKind.Batch, sink.Kind);
    }

    [Fact]
    public void Adls_sink_requires_account_identifier()
    {
        var config = new TargetConfig
        {
            TargetType = "ADLSGen2",
            Name = "adls",
            Properties = new Dictionary<string, object?> { ["filesystem"] = "raw" }
        };

        Assert.Throws<InvalidOperationException>(() => new AdlsGen2Sink(config));
    }

    [Fact]
    public async Task Write_before_open_throws()
    {
        var sink = new AdlsGen2Sink(Adls());
        var batch = new EntityBatch
        {
            SchemaArea = "core",
            EntityName = "Account",
            GeneratedAt = DateTimeOffset.UtcNow,
            Records = [new GeneratedRecord { Action = RecordAction.New, Key = 1, Fields = new Dictionary<string, object?>() }]
        };

        await Assert.ThrowsAsync<InvalidOperationException>(() => sink.WriteAsync(batch, CancellationToken.None));
    }
}

using DataGen.Abstractions;
using DataGen.Targets;
using Parquet;
using Parquet.Data;
using Parquet.Schema;
using Xunit;

namespace DataGen.Targets.Tests;

public class ParquetBatchWriterTests
{
    private static EntityBatch SampleBatch()
    {
        var at = new DateTimeOffset(2026, 8, 15, 10, 0, 0, TimeSpan.Zero);
        return new EntityBatch
        {
            SchemaArea = "core",
            EntityName = "Account",
            GeneratedAt = at,
            Records =
            [
                new GeneratedRecord
                {
                    Action = RecordAction.New,
                    Key = Guid.Parse("11111111-1111-1111-1111-111111111111"),
                    Fields = new Dictionary<string, object?>
                    {
                        ["name"] = "Acme",
                        ["amount"] = 10,
                        ["price"] = 19.99m,
                        ["active"] = true,
                        ["openedOn"] = at
                    }
                },
                new GeneratedRecord
                {
                    Action = RecordAction.Update,
                    Key = Guid.Parse("22222222-2222-2222-2222-222222222222"),
                    Fields = new Dictionary<string, object?>
                    {
                        ["name"] = "Globex",
                        ["amount"] = 25,
                        ["price"] = 5.50m,
                        ["active"] = false,
                        ["openedOn"] = at
                    }
                }
            ]
        };
    }

    [Fact]
    public async Task Writes_readable_parquet_with_expected_schema_and_rows()
    {
        byte[] bytes = await ParquetBatchWriter.WriteAsync(SampleBatch());

        using var stream = new MemoryStream(bytes);
        using ParquetReader reader = await ParquetReader.CreateAsync(stream);

        DataField[] fields = reader.Schema.GetDataFields();
        var names = fields.Select(f => f.Name).ToHashSet(StringComparer.Ordinal);
        Assert.Contains("_action", names);
        Assert.Contains("_key", names);
        Assert.Contains("_generatedAt", names);
        Assert.Contains("name", names);
        Assert.Contains("amount", names);
        Assert.Contains("price", names);
        Assert.Contains("active", names);
        Assert.Contains("openedOn", names);

        Assert.Equal(1, reader.RowGroupCount);
        using ParquetRowGroupReader rowGroup = reader.OpenRowGroupReader(0);
        Assert.Equal(2, rowGroup.RowCount);

        DataField nameField = fields.First(f => f.Name == "name");
        DataColumn nameColumn = await rowGroup.ReadColumnAsync(nameField);
        var values = nameColumn.Data.Cast<object?>().Select(v => v?.ToString()).ToArray();
        Assert.Equal(new[] { "Acme", "Globex" }, values);

        DataField actionField = fields.First(f => f.Name == "_action");
        DataColumn actionColumn = await rowGroup.ReadColumnAsync(actionField);
        Assert.Equal(new[] { "New", "Update" }, actionColumn.Data.Cast<object?>().Select(v => v?.ToString()).ToArray());
    }

    [Fact]
    public async Task Mixed_types_in_a_column_fall_back_to_string()
    {
        var at = DateTimeOffset.UtcNow;
        var batch = new EntityBatch
        {
            SchemaArea = "core",
            EntityName = "Mixed",
            GeneratedAt = at,
            Records =
            [
                new GeneratedRecord { Action = RecordAction.New, Key = 1, Fields = new Dictionary<string, object?> { ["x"] = 10 } },
                new GeneratedRecord { Action = RecordAction.New, Key = 2, Fields = new Dictionary<string, object?> { ["x"] = "ten" } }
            ]
        };

        byte[] bytes = await ParquetBatchWriter.WriteAsync(batch);
        using var stream = new MemoryStream(bytes);
        using ParquetReader reader = await ParquetReader.CreateAsync(stream);
        DataField x = reader.Schema.GetDataFields().First(f => f.Name == "x");
        Assert.Equal(typeof(string), x.ClrType);
    }
}

public class ParquetFactoryTests
{
    [Fact]
    public void Factory_creates_parquet_sink()
    {
        var factory = new SinkFactory();
        Assert.True(factory.CanCreate("ADLSGen2Parquet"));
        var config = new TargetConfig
        {
            TargetType = "ADLSGen2Parquet",
            Name = "adls-parquet",
            Properties = new Dictionary<string, object?> { ["accountName"] = "acct", ["filesystem"] = "raw" }
        };
        Assert.IsType<AdlsGen2ParquetSink>(factory.Create(config));
    }
}

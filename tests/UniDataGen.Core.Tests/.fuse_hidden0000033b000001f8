using DataGen.Abstractions;
using DataGen.Core;
using Xunit;

namespace DataGen.Core.Tests;

public class RateAccumulatorTests
{
    [Fact]
    public void Full_hour_at_base_rate_emits_rate()
    {
        var acc = new RateAccumulator();
        Assert.Equal(120, acc.Advance(120, 1.0, TimeSpan.FromHours(1)));
    }

    [Fact]
    public void Effective_multiplier_scales_emission()
    {
        var acc = new RateAccumulator();
        Assert.Equal(70, acc.Advance(100, 1.4, TimeSpan.FromMinutes(30)));
    }

    [Fact]
    public void Fractional_carry_accumulates_until_whole()
    {
        var acc = new RateAccumulator();
        Assert.Equal(0, acc.Advance(1, 1.0, TimeSpan.FromMinutes(30))); // 0.5 carried
        Assert.Equal(1, acc.Advance(1, 1.0, TimeSpan.FromMinutes(30))); // crosses 1.0
    }
}

public class BatchPlannerTests
{
    [Fact]
    public void Four_per_day_is_six_hour_interval()
        => Assert.Equal(TimeSpan.FromHours(6), BatchPlanner.Interval(new BatchFrequency(4, BatchUnit.Day)));

    [Fact]
    public void Due_fires_within_window()
    {
        var anchor = new DateTimeOffset(2026, 8, 15, 0, 0, 0, TimeSpan.Zero);
        var fires = BatchPlanner.DueFires(new BatchFrequency(4, BatchUnit.Day), anchor, anchor, anchor.AddHours(13));
        Assert.Equal(2, fires.Count); // +6h and +12h, +18h is past the window
        Assert.Equal(anchor.AddHours(6), fires[0]);
        Assert.Equal(anchor.AddHours(12), fires[1]);
    }

    [Theory]
    [InlineData(5000, 1.4, 7000)]
    [InlineData(5000, 0.0, 0)]
    [InlineData(100, 1.0, 100)]
    public void Batch_size_scales_with_effective(double perBatch, double effective, long expected)
        => Assert.Equal(expected, BatchPlanner.BatchSize(perBatch, effective));
}

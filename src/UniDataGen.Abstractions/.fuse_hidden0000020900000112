namespace DataGen.Abstractions;

/// <summary>One generated record with its action, key, and field values.</summary>
public sealed class GeneratedRecord
{
    public required RecordAction Action { get; init; }

    /// <summary>The primary key value. For New records this was minted by the engine.</summary>
    public required object Key { get; init; }

    /// <summary>Field name to value. Includes engine-stamped system fields and provider-supplied semantic fields.</summary>
    public required IReadOnlyDictionary<string, object?> Fields { get; init; }
}

/// <summary>A set of generated records for one entity, handed to a sink as a unit.</summary>
public sealed class EntityBatch
{
    public required string SchemaArea { get; init; }
    public required string EntityName { get; init; }
    public required DateTimeOffset GeneratedAt { get; init; }
    public required IReadOnlyList<GeneratedRecord> Records { get; init; }

    public string Key => $"{SchemaArea}/{EntityName}";
}

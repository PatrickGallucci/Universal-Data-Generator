namespace DataGen.Abstractions;

/// <summary>
/// Day-part multipliers applied to a base rate. 1.0 means the base rate as configured.
/// </summary>
public sealed record DayPartWeights(double Morning, double Afternoon, double Evening, double Night)
{
    /// <summary>Returns the multiplier for a given day part.</summary>
    public double For(DayPart part) => part switch
    {
        DayPart.Morning => Morning,
        DayPart.Afternoon => Afternoon,
        DayPart.Evening => Evening,
        DayPart.Night => Night,
        _ => throw new ArgumentOutOfRangeException(nameof(part), part, "Unknown day part.")
    };

    /// <summary>A neutral set where every part is 1.0.</summary>
    public static DayPartWeights Flat { get; } = new(1.0, 1.0, 1.0, 1.0);
}

/// <summary>The weekly weighting choice for an entity.</summary>
public sealed record EntitySchedule(
    ScheduleSplit Split,
    DayPartWeights? Week = null,
    DayPartWeights? Weekday = null,
    DayPartWeights? Weekend = null);

/// <summary>A per-action triple. Used for both per-hour (real-time) and per-batch counts.</summary>
public sealed record ActionRates(double New, double Update, double Delete)
{
    /// <summary>Returns the configured rate for a given action.</summary>
    public double For(RecordAction action) => action switch
    {
        RecordAction.New => New,
        RecordAction.Update => Update,
        RecordAction.Delete => Delete,
        _ => throw new ArgumentOutOfRangeException(nameof(action), action, "Unknown action.")
    };
}

/// <summary>Real-time settings: records per hour per action.</summary>
public sealed record RealtimeSettings(ActionRates PerHour);

/// <summary>How often a batch fires: a count against a unit, for example 4 per Day.</summary>
public sealed record BatchFrequency(int Count, BatchUnit Per);

/// <summary>Batch settings: cadence plus records per batch per action.</summary>
public sealed record BatchSettings(BatchFrequency Frequency, ActionRates PerBatch);

/// <summary>
/// A boost date that bends volume around a calendar event. Percentages apply as a multiplier:
/// factor = 1 + percent / 100. The window is symmetric with the peak day excluded from both shoulders.
/// </summary>
public sealed record BoostDate(
    DateOnly Date,
    double BoostPercent,
    int DaysBefore,
    int DaysAfter,
    double BoostPercentOnDate);

/// <summary>The full generation profile for one selected entity.</summary>
public sealed record EntityProfile
{
    public required string SchemaArea { get; init; }
    public required string EntityName { get; init; }
    public required GenerationMode Mode { get; init; }
    public required EntitySchedule Schedule { get; init; }
    public RealtimeSettings? Realtime { get; init; }
    public BatchSettings? Batch { get; init; }
    public IReadOnlyList<BoostDate> Boosts { get; init; } = [];

    /// <summary>IANA or Windows time zone id used to resolve day parts. Falls back to the run default when null.</summary>
    public string? TimeZoneId { get; init; }

    public string Key => $"{SchemaArea}/{EntityName}";
}

/// <summary>Foundry model deployment used by the value provider.</summary>
public sealed record FoundrySettings(
    string Endpoint,
    string Deployment,
    string AuthMethod = "ManagedIdentity",
    string? ApiKeySecretRef = null);

/// <summary>The run header: what was picked and which Foundry deployment to use.</summary>
public sealed record RunHeader(string Industry, string SourceType, FoundrySettings Foundry, string? DefaultTimeZoneId = null);

/// <summary>Authentication block for a target, mirroring data-targets.schema.json.</summary>
public sealed record TargetAuth(string Method, string? KeyVaultSecretRef = null);

/// <summary>A single target, mirroring an entry in data-targets.schema.json.</summary>
public sealed record TargetConfig
{
    public required string TargetType { get; init; }
    public required string Name { get; init; }
    public bool Enabled { get; init; } = true;
    public TargetAuth Authentication { get; init; } = new("ManagedIdentity");
    public IReadOnlyDictionary<string, object?> Properties { get; init; } = new Dictionary<string, object?>();
}

/// <summary>The complete run configuration shared by every host.</summary>
public sealed record RunConfiguration
{
    public required RunHeader Run { get; init; }
    public IReadOnlyList<EntityProfile> Entities { get; init; } = [];
    public IReadOnlyList<TargetConfig> Targets { get; init; } = [];
}

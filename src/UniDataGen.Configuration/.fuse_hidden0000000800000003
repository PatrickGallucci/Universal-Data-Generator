using DataGen.Abstractions;
using DocumentFormat.OpenXml;
using DocumentFormat.OpenXml.Packaging;
using DocumentFormat.OpenXml.Spreadsheet;
using Microsoft.Extensions.Logging;
using Microsoft.Extensions.Logging.Abstractions;

namespace DataGen.Configuration;

/// <summary>
/// Reads the catalog workbook into a <see cref="Catalog"/>. Sheets are streamed with an OpenXmlReader so the
/// large Attributes sheet (well over one hundred thousand rows) is processed row by row rather than loaded whole.
/// </summary>
public sealed class WorkbookCatalogReader
{
    private const string IndustrySheet = "Industry";
    private const string SourceTypeSheet = "SourceType";
    private const string StorageSheet = "Storage";
    private const string AttributesSheet = "Attributes";

    private readonly ILogger _logger;

    /// <summary>Creates a reader. Pass a logger to record catalog load metrics.</summary>
    public WorkbookCatalogReader(ILogger? logger = null) => _logger = logger ?? NullLogger.Instance;

    /// <summary>Reads the catalog from a workbook path.</summary>
    public Catalog Read(string workbookPath)
    {
        ArgumentException.ThrowIfNullOrWhiteSpace(workbookPath);
        if (!File.Exists(workbookPath))
        {
            throw new FileNotFoundException("Catalog workbook not found.", workbookPath);
        }

        using SpreadsheetDocument document = SpreadsheetDocument.Open(workbookPath, isEditable: false);
        WorkbookPart workbookPart = document.WorkbookPart
            ?? throw new InvalidDataException("Workbook part missing from the spreadsheet.");

        string[] sharedStrings = LoadSharedStrings(workbookPart);

        var industries = ReadRows(workbookPart, IndustrySheet, sharedStrings, skipHeader: true)
            .Where(r => r.Get(0) is { Length: > 0 })
            .Select(r => new IndustryInfo(r.Get(0)!, r.Get(1)))
            .ToList();

        var sourceTypes = ReadRows(workbookPart, SourceTypeSheet, sharedStrings, skipHeader: true)
            .Where(r => r.Get(0) is { Length: > 0 })
            .Select(r => new SourceTypeInfo(r.Get(0)!, r.Get(1) ?? string.Empty, r.Get(2)))
            .ToList();

        var storages = ReadRows(workbookPart, StorageSheet, sharedStrings, skipHeader: true)
            .Where(r => r.Get(0) is { Length: > 0 })
            .Select(r => new StorageInfo(r.Get(0)!.Trim(), r.Get(1)))
            .ToList();

        var entities = ReadEntities(workbookPart, sharedStrings);

        return new Catalog(industries, sourceTypes, storages, entities);
    }

    // Attributes sheet columns:
    // 0 SchemaArea, 1 EntityName, 2 EntityDisplayName, 3 EntityDescription, 4 ExtendsEntity,
    // 5 AttributeName, 6 AttributeDisplayName, 7 AttributeDescription, 8 DataType, 9 Purpose,
    // 10 IsNullable, 11 SourceName, 12 SourceOrdering
    private static List<EntityInfo> ReadEntities(WorkbookPart workbookPart, string[] sharedStrings)
    {
        var builders = new Dictionary<string, EntityBuilder>(StringComparer.OrdinalIgnoreCase);

        foreach (Row row in ReadRows(workbookPart, AttributesSheet, sharedStrings, skipHeader: true))
        {
            string? schemaArea = row.Get(0);
            string? entityName = row.Get(1);
            if (string.IsNullOrEmpty(schemaArea) || string.IsNullOrEmpty(entityName))
            {
                continue;
            }

            string key = $"{schemaArea}/{entityName}";
            if (!builders.TryGetValue(key, out EntityBuilder? builder))
            {
                builder = new EntityBuilder(schemaArea, entityName, row.Get(2), row.Get(3), row.Get(4));
                builders[key] = builder;
            }

            string? attributeName = row.Get(5);
            if (string.IsNullOrEmpty(attributeName))
            {
                continue; // relationship or header-only row, no scalar attribute
            }

            builder.Attributes.Add(new AttributeInfo(
                Name: attributeName,
                DisplayName: row.Get(6),
                Description: row.Get(7),
                DataType: row.Get(8) is { Length: > 0 } dt ? dt : "string",
                Purpose: row.Get(9),
                IsNullable: ParseBool(row.Get(10)),
                SourceName: row.Get(11),
                SourceOrdering: int.TryParse(row.Get(12), out int ord) ? ord : null));
        }

        return builders.Values.Select(b => b.Build()).ToList();
    }

    private static bool ParseBool(string? value)
        => value is { Length: > 0 } && (value.Equals("true", StringComparison.OrdinalIgnoreCase) || value == "1");

    private static string[] LoadSharedStrings(WorkbookPart workbookPart)
    {
        SharedStringTablePart? part = workbookPart.SharedStringTablePart;
        if (part?.SharedStringTable is null)
        {
            return [];
        }

        var values = new List<string>();
        foreach (SharedStringItem item in part.SharedStringTable.Elements<SharedStringItem>())
        {
            values.Add(item.InnerText);
        }

        return [.. values];
    }

    private static IEnumerable<Row> ReadRows(WorkbookPart workbookPart, string sheetName, string[] sharedStrings, bool skipHeader)
    {
        Sheet? sheet = workbookPart.Workbook.Descendants<Sheet>()
            .FirstOrDefault(s => string.Equals(s.Name?.Value, sheetName, StringComparison.OrdinalIgnoreCase));
        if (sheet?.Id?.Value is not { } relId)
        {
            yield break;
        }

        var worksheetPart = (WorksheetPart)workbookPart.GetPartById(relId);
        using OpenXmlReader reader = OpenXmlReader.Create(worksheetPart);

        bool headerSkipped = !skipHeader;
        while (reader.Read())
        {
            if (reader.ElementType != typeof(DocumentFormat.OpenXml.Spreadsheet.Row))
            {
                continue;
            }
            var rowElement = (DocumentFormat.OpenXml.Spreadsheet.Row)reader.LoadCurrentElement()!;
            if (!headerSkipped)
            {
                headerSkipped = true;
                continue;
            }

            yield return ToRow(rowElement, sharedStrings);
        }
    }

    private static Row ToRow(DocumentFormat.OpenXml.Spreadsheet.Row rowElement, string[] sharedStrings)
    {
        var cells = new Dictionary<int, string?>();
        foreach (Cell cell in rowElement.Elements<Cell>())
        {
            int column = CellReference.ColumnIndex(cell.CellReference?.Value);
            if (column < 0)
            {
                continue;
            }

            cells[column] = ResolveValue(cell, sharedStrings);
        }

        return new Row(cells);
    }

    private static string? ResolveValue(Cell cell, string[] sharedStrings)
    {
        string? raw = cell.CellValue?.InnerText;
        if (cell.DataType?.Value == CellValues.SharedString)
        {
            return int.TryParse(raw, out int idx) && idx >= 0 && idx < sharedStrings.Length ? sharedStrings[idx] : null;
        }

        if (cell.DataType?.Value == CellValues.InlineString)
        {
            return cell.InlineString?.Text?.Text ?? cell.InnerText;
        }

        return raw;
    }

    private sealed class EntityBuilder(string schemaArea, string entityName, string? displayName, string? description, string? extends)
    {
        public List<AttributeInfo> Attributes { get; } = [];

        public EntityInfo Build()
            => new(schemaArea, entityName, displayName, description, extends, Attributes);
    }

    /// <summary>A sparse spreadsheet row keyed by zero-based column index.</summary>
    private readonly struct Row(Dictionary<int, string?> cells)
    {
        public string? Get(int column) => cells.TryGetValue(column, out string? value) ? value : null;
    }
}

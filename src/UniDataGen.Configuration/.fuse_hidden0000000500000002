using DataGen.Abstractions;

namespace DataGen.Configuration;

/// <summary>The outcome of validating a run configuration against the catalog.</summary>
public sealed record ValidationResult(bool IsValid, IReadOnlyList<string> Errors)
{
    public static ValidationResult Ok { get; } = new(true, []);
}

/// <summary>
/// Validates a run configuration against the catalog so a run fails loud at load rather than halfway through.
/// </summary>
public sealed class RunConfigurationValidator
{
    private static readonly HashSet<string> KnownTargetTypes = new(StringComparer.OrdinalIgnoreCase)
    {
        "ADLSGen2", "AzureAISearchIndex", "AzureBlobStorage", "AzureCosmosDB", "AzureDataShare",
        "AzureEventGrid", "AzureFiles", "AzureServiceBus", "AzureSqlDB", "DatabricksUC", "Dataverse",
        "EventHubs", "FabricEventhouse", "OneLakeLakehouse", "OneLakeWarehouse", "PostgreSQL",
        "ADLSGen2Parquet", "JsonFile", "Console", "Null"
    };

    /// <summary>Returns all problems found, or an empty list when the configuration is valid.</summary>
    public ValidationResult Validate(RunConfiguration config, Catalog catalog)
    {
        ArgumentNullException.ThrowIfNull(config);
        ArgumentNullException.ThrowIfNull(catalog);

        var errors = new List<string>();

        if (!catalog.HasIndustry(config.Run.Industry))
        {
            errors.Add($"Industry '{config.Run.Industry}' is not in the catalog.");
        }

        if (!catalog.HasSourceType(config.Run.SourceType))
        {
            errors.Add($"Source type '{config.Run.SourceType}' is not in the catalog.");
        }

        if (config.Entities.Count == 0)
        {
            errors.Add("No entities selected.");
        }

        foreach (EntityProfile entity in config.Entities)
        {
            ValidateEntity(entity, catalog, errors);
        }

        if (config.Targets.Count(t => t.Enabled) == 0)
        {
            errors.Add("No enabled targets.");
        }

        foreach (TargetConfig target in config.Targets)
        {
            if (!KnownTargetTypes.Contains(target.TargetType))
            {
                errors.Add($"Target '{target.Name}' has unknown type '{target.TargetType}'.");
            }
        }

        return errors.Count == 0 ? ValidationResult.Ok : new ValidationResult(false, errors);
    }

    private static void ValidateEntity(EntityProfile entity, Catalog catalog, List<string> errors)
    {
        if (catalog.FindEntity(entity.SchemaArea, entity.EntityName) is null)
        {
            errors.Add($"Entity '{entity.Key}' is not in the catalog.");
        }

        switch (entity.Mode)
        {
            case GenerationMode.RealTime when entity.Realtime is null:
                errors.Add($"Entity '{entity.Key}' is real-time but has no realtime settings.");
                break;
            case GenerationMode.Batch when entity.Batch is null:
                errors.Add($"Entity '{entity.Key}' is batch but has no batch settings.");
                break;
            case GenerationMode.Batch when entity.Batch is { Frequency.Count: <= 0 }:
                errors.Add($"Entity '{entity.Key}' has a non-positive batch frequency.");
                break;
        }

        foreach (BoostDate boost in entity.Boosts)
        {
            if (boost.DaysBefore < 0 || boost.DaysAfter < 0)
            {
                errors.Add($"Entity '{entity.Key}' has a boost on {boost.Date:yyyy-MM-dd} with a negative window.");
            }
        }
    }
}

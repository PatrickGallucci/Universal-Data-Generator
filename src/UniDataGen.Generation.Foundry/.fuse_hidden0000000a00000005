using System.Net.Http.Headers;
using System.Net.Http.Json;
using System.Text;
using System.Text.Json;
using Azure.Core;
using Azure.Identity;
using DataGen.Abstractions;
using Microsoft.Extensions.Logging;
using Microsoft.Extensions.Logging.Abstractions;

namespace DataGen.Generation.Foundry;

/// <summary>
/// An <see cref="IValueProvider"/> backed by an Azure AI Foundry chat model deployment. It requests structured
/// output (a JSON schema derived from the entity's semantic attributes) and coerces the result to CDM types.
/// Identity, audit, and state fields are not requested here; the engine stamps those.
/// </summary>
public sealed class FoundryValueProvider : IValueProvider, IDisposable
{
    private const string TokenScope = "https://cognitiveservices.azure.com/.default";
    private readonly FoundrySettings _settings;
    private readonly HttpClient _http;
    private readonly TokenCredential? _credential;
    private readonly string? _apiKey;
    private readonly bool _ownsHttp;
    private readonly string _apiVersion;
    private readonly ILogger _logger;

    /// <summary>
    /// Creates a provider. When <paramref name="apiKey"/> is null the provider uses Entra tokens via
    /// <paramref name="credential"/> (defaulting to <see cref="DefaultAzureCredential"/>).
    /// </summary>
    public FoundryValueProvider(
        FoundrySettings settings,
        HttpClient? httpClient = null,
        TokenCredential? credential = null,
        string? apiKey = null,
        string apiVersion = "2024-10-21",
        ILogger? logger = null)
    {
        ArgumentNullException.ThrowIfNull(settings);
        _settings = settings;
        _http = httpClient ?? new HttpClient();
        _ownsHttp = httpClient is null;
        _apiKey = apiKey;
        _apiVersion = apiVersion;
        _credential = apiKey is null ? credential ?? new DefaultAzureCredential() : null;
        _logger = logger ?? NullLogger.Instance;
    }

    /// <inheritdoc />
    public async Task<IReadOnlyList<IReadOnlyDictionary<string, object?>>> GenerateAsync(ValueRequest request, CancellationToken cancellationToken)
    {
        ArgumentNullException.ThrowIfNull(request);
        if (request.Count <= 0)
        {
            return [];
        }

        JsonElement schema = FoundryPromptBuilder.RecordsSchema(request.SemanticAttributes);
        object payload = new
        {
            messages = new object[]
            {
                new { role = "system", content = FoundryPromptBuilder.SystemPrompt(request.Industry, request.SourceType) },
                new { role = "user", content = FoundryPromptBuilder.UserPrompt(request.Entity, request.Count) }
            },
            temperature = 0.7,
            response_format = new
            {
                type = "json_schema",
                json_schema = new { name = "records", strict = true, schema }
            }
        };

        using HttpRequestMessage message = await BuildRequestAsync(payload, cancellationToken).ConfigureAwait(false);
        using HttpResponseMessage response = await _http.SendAsync(message, cancellationToken).ConfigureAwait(false);
        response.EnsureSuccessStatusCode();

        await using Stream stream = await response.Content.ReadAsStreamAsync(cancellationToken).ConfigureAwait(false);
        using JsonDocument document = await JsonDocument.ParseAsync(stream, cancellationToken: cancellationToken).ConfigureAwait(false);

        string content = document.RootElement
            .GetProperty("choices")[0]
            .GetProperty("message")
            .GetProperty("content")
            .GetString() ?? "{}";

        return Parse(content, request.SemanticAttributes);
    }

    private async Task<HttpRequestMessage> BuildRequestAsync(object payload, CancellationToken cancellationToken)
    {
        string url = $"{_settings.Endpoint.TrimEnd('/')}/openai/deployments/{_settings.Deployment}/chat/completions?api-version={_apiVersion}";
        var message = new HttpRequestMessage(HttpMethod.Post, url)
        {
            Content = JsonContent.Create(payload)
        };

        if (_apiKey is { } key)
        {
            message.Headers.Add("api-key", key);
        }
        else
        {
            AccessToken token = await _credential!
                .GetTokenAsync(new TokenRequestContext([TokenScope]), cancellationToken)
                .ConfigureAwait(false);
            message.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token.Token);
        }

        return message;
    }

    private static List<IReadOnlyDictionary<string, object?>> Parse(string content, IReadOnlyList<AttributeInfo> semantic)
    {
        var typeByName = semantic.ToDictionary(a => a.Name, a => a.DataType, StringComparer.Ordinal);
        var results = new List<IReadOnlyDictionary<string, object?>>();

        using JsonDocument doc = JsonDocument.Parse(content);
        if (!doc.RootElement.TryGetProperty("records", out JsonElement records) || records.ValueKind != JsonValueKind.Array)
        {
            return results;
        }

        foreach (JsonElement record in records.EnumerateArray())
        {
            var row = new Dictionary<string, object?>(StringComparer.Ordinal);
            foreach (JsonProperty property in record.EnumerateObject())
            {
                string dataType = typeByName.TryGetValue(property.Name, out string? dt) ? dt : "string";
                row[property.Name] = CdmTypeCoercion.Coerce(property.Value, dataType);
            }

            results.Add(row);
        }

        return results;
    }

    /// <inheritdoc />
    public void Dispose()
    {
        if (_ownsHttp)
        {
            _http.Dispose();
        }
    }
}

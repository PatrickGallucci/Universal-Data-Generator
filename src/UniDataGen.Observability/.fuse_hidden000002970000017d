using Microsoft.Extensions.Logging;

namespace DataGen.Observability;

/// <summary>
/// Builds logger factories that send structured logs to Azure Application Insights, optionally alongside a
/// host-supplied sink (UI text box, console). Every tier of the generator logs through ILogger, so wiring the
/// factory once at the host boundary captures Core, Configuration, Foundry, and the target adapters.
/// </summary>
public static class AppInsightsLogging
{
    /// <summary>
    /// Creates a logger factory wired to Application Insights when a connection string is available, plus any
    /// extra providers supplied through <paramref name="configure"/>. The connection string falls back to the
    /// APPLICATIONINSIGHTS_CONNECTION_STRING environment variable.
    /// </summary>
    public static ILoggerFactory CreateFactory(
        string? connectionString = null,
        LogLevel minimumLevel = LogLevel.Information,
        Action<ILoggingBuilder>? configure = null)
    {
        connectionString ??= Environment.GetEnvironmentVariable("APPLICATIONINSIGHTS_CONNECTION_STRING");

        return LoggerFactory.Create(builder =>
        {
            builder.SetMinimumLevel(minimumLevel);

            if (!string.IsNullOrWhiteSpace(connectionString))
            {
                builder.AddApplicationInsights(
                    configureTelemetryConfiguration: config => config.ConnectionString = connectionString,
                    configureApplicationInsightsLoggerOptions: _ => { });
            }

            configure?.Invoke(builder);
        });
    }

    /// <summary>Adds a delegate provider that forwards formatted messages to <paramref name="sink"/>.</summary>
    public static ILoggingBuilder AddDelegate(this ILoggingBuilder builder, Action<string> sink, LogLevel minLevel = LogLevel.Information)
    {
        builder.AddProvider(new DelegateLoggerProvider(sink, minLevel));
        return builder;
    }
}

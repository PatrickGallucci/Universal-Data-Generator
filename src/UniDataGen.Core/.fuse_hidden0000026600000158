using DataGen.Abstractions;
using Microsoft.Extensions.Logging;
using Microsoft.Extensions.Logging.Abstractions;

namespace DataGen.Core;

/// <summary>
/// The run loop. Resolves each selected entity against the catalog, drives real-time accrual and batch
/// cadence, builds batches through the value coordinator, and writes to every enabled sink. Scheduling and
/// counting are delegated to the pure helpers, so this class owns orchestration, I/O, and structured logging.
/// </summary>
public sealed class GenerationOrchestrator
{
    private readonly Catalog _catalog;
    private readonly IValueProvider _provider;
    private readonly ISinkFactory _sinkFactory;
    private readonly ILoggerFactory _loggerFactory;
    private readonly ILogger<GenerationOrchestrator> _logger;

    public GenerationOrchestrator(Catalog catalog, IValueProvider provider, ISinkFactory sinkFactory, ILoggerFactory? loggerFactory = null)
    {
        ArgumentNullException.ThrowIfNull(catalog);
        ArgumentNullException.ThrowIfNull(provider);
        ArgumentNullException.ThrowIfNull(sinkFactory);

        _catalog = catalog;
        _provider = provider;
        _sinkFactory = sinkFactory;
        _loggerFactory = loggerFactory ?? NullLoggerFactory.Instance;
        _logger = _loggerFactory.CreateLogger<GenerationOrchestrator>();
    }

    /// <summary>
    /// Runs the configuration until cancellation. Validates the run header against the catalog,
    /// opens every enabled sink, then runs each entity concurrently. A run-scoped correlation id is
    /// attached to every log entry.
    /// </summary>
    public async Task RunAsync(RunConfiguration config, TimeSpan tickInterval, CancellationToken cancellationToken)
    {
        ArgumentNullException.ThrowIfNull(config);

        string runId = Guid.NewGuid().ToString("N");
        using IDisposable? runScope = _logger.BeginScope(new Dictionary<string, object>
        {
            ["RunId"] = runId,
            ["Industry"] = config.Run.Industry,
            ["SourceType"] = config.Run.SourceType
        });

        if (!_catalog.HasIndustry(config.Run.Industry))
        {
            _logger.LogError("Industry {Industry} is not in the catalog.", config.Run.Industry);
            throw new InvalidOperationException($"Industry '{config.Run.Industry}' is not in the catalog.");
        }

        if (!_catalog.HasSourceType(config.Run.SourceType))
        {
            _logger.LogError("Source type {SourceType} is not in the catalog.", config.Run.SourceType);
            throw new InvalidOperationException($"Source type '{config.Run.SourceType}' is not in the catalog.");
        }

        _logger.LogInformation("Run {RunId} starting: {Entities} entities, industry {Industry}, source {SourceType}.",
            runId, config.Entities.Count, config.Run.Industry, config.Run.SourceType);

        var sinks = new List<ISink>();
        foreach (TargetConfig target in config.Targets.Where(t => t.Enabled))
        {
            ISink sink = _sinkFactory.Create(target);
            await sink.OpenAsync(cancellationToken).ConfigureAwait(false);
            sinks.Add(sink);
            _logger.LogInformation("Opened sink {TargetType}:{TargetName} ({Kind}).", target.TargetType, target.Name, sink.Kind);
        }

        if (sinks.Count == 0)
        {
            _logger.LogWarning("No enabled targets; generated records will be discarded.");
        }

        var stopwatch = System.Diagnostics.Stopwatch.StartNew();

        try
        {
            ILogger coordinatorLogger = _loggerFactory.CreateLogger("DataGen.Core.ValueCoordinator");
            var coordinator = new ValueCoordinator(_provider, coordinatorLogger);
            DateTimeOffset runStart = DateTimeOffset.UtcNow;

            IEnumerable<Task> entityTasks = config.Entities.Select(profile =>
                RunEntityAsync(profile, config.Run, coordinator, sinks, runStart, tickInterval, cancellationToken));

            await Task.WhenAll(entityTasks).ConfigureAwait(false);
        }
        catch (OperationCanceledException)
        {
            _logger.LogInformation("Run {RunId} cancelled after {Elapsed}.", runId, stopwatch.Elapsed);
        }
        finally
        {
            foreach (ISink sink in sinks)
            {
                await sink.DisposeAsync().ConfigureAwait(false);
            }

            _logger.LogInformation("Run {RunId} ended after {Elapsed}.", runId, stopwatch.Elapsed);
        }
    }

    private async Task RunEntityAsync(
        EntityProfile profile,
        RunHeader run,
        ValueCoordinator coordinator,
        IReadOnlyList<ISink> sinks,
        DateTimeOffset runStart,
        TimeSpan tickInterval,
        CancellationToken cancellationToken)
    {
        using IDisposable? entityScope = _logger.BeginScope(new Dictionary<string, object>
        {
            ["Entity"] = profile.Key,
            ["Mode"] = profile.Mode.ToString()
        });

        EntityInfo? entity = _catalog.FindEntity(profile.SchemaArea, profile.EntityName);
        if (entity is null)
        {
            _logger.LogWarning("Skipping {Entity}: not found in catalog.", profile.Key);
            return;
        }

        string timeZone = profile.TimeZoneId ?? run.DefaultTimeZoneId ?? string.Empty;
        string locale = string.IsNullOrWhiteSpace(profile.Locale) ? run.Locale : profile.Locale!;
        var pool = new IdentityPool();
        _logger.LogInformation("Entity {Entity} started in {Mode} mode.", profile.Key, profile.Mode);

        try
        {
            if (profile.Mode == GenerationMode.RealTime)
            {
                await RunRealTimeAsync(profile, entity, run, coordinator, sinks, pool, timeZone, locale, tickInterval, cancellationToken).ConfigureAwait(false);
            }
            else
            {
                await RunBatchAsync(profile, entity, run, coordinator, sinks, pool, runStart, timeZone, locale, tickInterval, cancellationToken).ConfigureAwait(false);
            }
        }
        catch (OperationCanceledException)
        {
            _logger.LogDebug("Entity {Entity} stopped.", profile.Key);
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Entity {Entity} failed.", profile.Key);
            throw;
        }
    }

    private async Task RunRealTimeAsync(
        EntityProfile profile,
        EntityInfo entity,
        RunHeader run,
        ValueCoordinator coordinator,
        IReadOnlyList<ISink> sinks,
        IdentityPool pool,
        string timeZone,
        string locale,
        TimeSpan tickInterval,
        CancellationToken cancellationToken)
    {
        RealtimeSettings settings = profile.Realtime
            ?? throw new InvalidOperationException($"Entity '{profile.Key}' is real-time but has no realtime settings.");

        var accNew = new RateAccumulator();
        var accUpdate = new RateAccumulator();
        var accDelete = new RateAccumulator();
        DateTimeOffset last = DateTimeOffset.UtcNow;

        while (!cancellationToken.IsCancellationRequested)
        {
            await Task.Delay(tickInterval, cancellationToken).ConfigureAwait(false);

            DateTimeOffset now = DateTimeOffset.UtcNow;
            TimeSpan elapsed = now - last;
            last = now;

            DateTimeOffset local = TimeZoneResolver.ToLocal(now, timeZone);
            double effective = EffectiveMultiplier.At(profile, local);

            var owed = new OwedCounts(
                accNew.Advance(settings.PerHour.New, effective, elapsed),
                accUpdate.Advance(settings.PerHour.Update, effective, elapsed),
                accDelete.Advance(settings.PerHour.Delete, effective, elapsed));

            await EmitAsync(entity, run, coordinator, sinks, pool, owed, locale, now, cancellationToken).ConfigureAwait(false);
        }
    }

    private async Task RunBatchAsync(
        EntityProfile profile,
        EntityInfo entity,
        RunHeader run,
        ValueCoordinator coordinator,
        IReadOnlyList<ISink> sinks,
        IdentityPool pool,
        DateTimeOffset runStart,
        string timeZone,
        string locale,
        TimeSpan tickInterval,
        CancellationToken cancellationToken)
    {
        BatchSettings settings = profile.Batch
            ?? throw new InvalidOperationException($"Entity '{profile.Key}' is batch but has no batch settings.");

        DateTimeOffset lastCheck = DateTimeOffset.UtcNow;

        while (!cancellationToken.IsCancellationRequested)
        {
            await Task.Delay(tickInterval, cancellationToken).ConfigureAwait(false);

            DateTimeOffset now = DateTimeOffset.UtcNow;
            IReadOnlyList<DateTimeOffset> fires = BatchPlanner.DueFires(settings.Frequency, runStart, lastCheck, now);
            lastCheck = now;

            foreach (DateTimeOffset fire in fires)
            {
                DateTimeOffset local = TimeZoneResolver.ToLocal(fire, timeZone);
                double effective = EffectiveMultiplier.At(profile, local);
                OwedCounts owed = Planner.BatchOwed(settings, effective);
                _logger.LogDebug("Batch fired for {Entity} at {Fire}: {New}/{Update}/{Delete} (x{Effective:0.00}).",
                    entity.Key, fire, owed.New, owed.Update, owed.Delete, effective);
                await EmitAsync(entity, run, coordinator, sinks, pool, owed, locale, fire, cancellationToken).ConfigureAwait(false);
            }
        }
    }

    private async Task EmitAsync(
        EntityInfo entity,
        RunHeader run,
        ValueCoordinator coordinator,
        IReadOnlyList<ISink> sinks,
        IdentityPool pool,
        OwedCounts owed,
        string locale,
        DateTimeOffset at,
        CancellationToken cancellationToken)
    {
        if (owed.IsEmpty)
        {
            return;
        }

        EntityBatch batch = await coordinator
            .BuildAsync(entity, run.Industry, run.SourceType, locale, owed.New, owed.Update, owed.Delete, pool, at, cancellationToken)
            .ConfigureAwait(false);

        if (batch.Records.Count == 0)
        {
            return;
        }

        foreach (ISink sink in sinks)
        {
            try
            {
                await sink.WriteAsync(batch, cancellationToken).ConfigureAwait(false);
            }
            catch (Exception ex) when (ex is not OperationCanceledException)
            {
                _logger.LogError(ex, "Sink {TargetType} failed writing {Count} records for {Entity}.",
                    sink.TargetType, batch.Records.Count, entity.Key);
                throw;
            }
        }

        _logger.LogDebug("{Entity}: wrote {Count} records at {At:O}.", entity.Key, batch.Records.Count, at);
    }
}

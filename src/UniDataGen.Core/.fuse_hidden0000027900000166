using DataGen.Abstractions;

namespace DataGen.Core;

/// <summary>Stamps engine-owned system fields onto a record: identity, audit stamps, and a default state.</summary>
public static class SystemFieldStamper
{
    /// <summary>
    /// Writes system field values into <paramref name="fields"/> based on each attribute's Purpose and datatype.
    /// </summary>
    public static void Stamp(EntityInfo entity, IDictionary<string, object?> fields, object key, DateTimeOffset at, RecordAction action)
    {
        foreach (AttributeInfo attribute in entity.Attributes)
        {
            if (!AttributeClassifier.IsSystemField(attribute))
            {
                continue;
            }

            object? value = attribute.Purpose switch
            {
                "identifiedBy" => key,
                "createdOn" => at,
                "modifiedOn" => at,
                "representsStateWith" => action == RecordAction.Delete ? 1 : 0, // 0 active, 1 inactive
                _ => attribute.DataType switch
                {
                    "guid" => key is Guid ? key : Guid.NewGuid(),
                    "entityId" => key,
                    "RefRecId" => key,
                    _ => null
                }
            };

            fields[attribute.Name] = value;
        }
    }
}

using DataGen.Abstractions;

namespace DataGen.Core;

/// <summary>Computes batch cadence and batch size. Cadence is fixed by frequency; size flexes with the effective multiplier.</summary>
public static class BatchPlanner
{
    private const double HoursPerMonth = 730.5; // 365.25 days / 12 months, in hours

    /// <summary>The interval between batch fires for a frequency, for example 4 per Day gives 6 hours.</summary>
    public static TimeSpan Interval(BatchFrequency frequency)
    {
        if (frequency.Count <= 0)
        {
            throw new ArgumentOutOfRangeException(nameof(frequency), frequency.Count, "Frequency count must be positive.");
        }

        double hoursPerUnit = frequency.Per switch
        {
            BatchUnit.Hour => 1.0,
            BatchUnit.Day => 24.0,
            BatchUnit.Week => 168.0,
            BatchUnit.Month => HoursPerMonth,
            _ => throw new ArgumentOutOfRangeException(nameof(frequency), frequency.Per, "Unknown batch unit.")
        };

        return TimeSpan.FromHours(hoursPerUnit / frequency.Count);
    }

    /// <summary>
    /// Returns the fire times in the half-open window (after, until], measured from an anchor (typically the run start).
    /// </summary>
    public static IReadOnlyList<DateTimeOffset> DueFires(BatchFrequency frequency, DateTimeOffset anchor, DateTimeOffset after, DateTimeOffset until)
    {
        TimeSpan interval = Interval(frequency);
        var fires = new List<DateTimeOffset>();

        // Smallest k such that anchor + k*interval > after.
        double sinceAnchor = (after - anchor) / interval;
        long k = (long)Math.Floor(sinceAnchor) + 1;
        if (k < 0)
        {
            k = 0;
        }

        DateTimeOffset fire = anchor + interval * k;
        while (fire <= until)
        {
            if (fire > after)
            {
                fires.Add(fire);
            }

            k++;
            fire = anchor + interval * k;
        }

        return fires;
    }

    /// <summary>The record count for a batch action: round(perBatch * effective) away from zero.</summary>
    public static long BatchSize(double perBatch, double effective)
    {
        double size = perBatch * effective;
        return size <= 0 ? 0 : (long)Math.Round(size, MidpointRounding.AwayFromZero);
    }
}

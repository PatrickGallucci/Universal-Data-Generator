using DataGen.Abstractions;

namespace DataGen.Core;

/// <summary>Maps a wall-clock hour to one of the four day parts.</summary>
public static class DayPartCalculator
{
    /// <summary>Returns the day part for an hour in 0..23. Night 0-6, Morning 6-12, Afternoon 12-18, Evening 18-24.</summary>
    /// <exception cref="ArgumentOutOfRangeException">Thrown when <paramref name="hour"/> is outside 0..23.</exception>
    public static DayPart FromHour(int hour)
    {
        if (hour is < 0 or > 23)
        {
            throw new ArgumentOutOfRangeException(nameof(hour), hour, "Hour must be between 0 and 23.");
        }

        return hour switch
        {
            >= 6 and < 12 => DayPart.Morning,
            >= 12 and < 18 => DayPart.Afternoon,
            >= 18 and < 24 => DayPart.Evening,
            _ => DayPart.Night
        };
    }

    /// <summary>Returns the day part for a local time.</summary>
    public static DayPart FromTime(DateTimeOffset localTime) => FromHour(localTime.Hour);
}

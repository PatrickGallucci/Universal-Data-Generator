using DataGen.Abstractions;
using Microsoft.Extensions.Logging;
using Microsoft.Extensions.Logging.Abstractions;

namespace DataGen.Core;

/// <summary>
/// Turns owed record counts into a concrete <see cref="EntityBatch"/>. Semantic fields come from the
/// value provider; identity, audit, and state fields are stamped by the engine.
/// </summary>
public sealed class ValueCoordinator
{
    private readonly IValueProvider _provider;
    private readonly ILogger _logger;

    public ValueCoordinator(IValueProvider provider, ILogger? logger = null)
    {
        ArgumentNullException.ThrowIfNull(provider);
        _provider = provider;
        _logger = logger ?? NullLogger.Instance;
    }

    /// <summary>
    /// Builds a batch for the given owed counts. New records mint keys and add them to the pool;
    /// Update and Delete draw keys from the pool and are skipped while it is warming up (empty).
    /// </summary>
    public async Task<EntityBatch> BuildAsync(
        EntityInfo entity,
        string industry,
        string sourceType,
        string locale,
        long newCount,
        long updateCount,
        long deleteCount,
        IdentityPool pool,
        DateTimeOffset at,
        CancellationToken cancellationToken)
    {
        ArgumentNullException.ThrowIfNull(entity);
        ArgumentNullException.ThrowIfNull(pool);

        IReadOnlyList<AttributeInfo> semantic = AttributeClassifier.SemanticAttributes(entity);
        var records = new List<GeneratedRecord>(checked((int)Math.Min(newCount + updateCount + deleteCount, int.MaxValue)));

        if (newCount > 0)
        {
            _logger.LogDebug("Requesting {Count} new {Entity} records from the value provider.", newCount, entity.Key);
            IReadOnlyList<IReadOnlyDictionary<string, object?>> values =
                await RequestAsync(entity, industry, sourceType, (int)newCount, semantic, cancellationToken).ConfigureAwait(false);

            foreach (IReadOnlyDictionary<string, object?> value in values)
            {
                object key = Guid.NewGuid();
                var fields = new Dictionary<string, object?>(value, StringComparer.Ordinal);
                SystemFieldStamper.Stamp(entity, fields, key, at, RecordAction.New);
                pool.Add(key);
                records.Add(new GeneratedRecord { Action = RecordAction.New, Key = key, Fields = fields });
            }
        }

        if (updateCount > 0 && pool.Count > 0)
        {
            IReadOnlyList<IReadOnlyDictionary<string, object?>> values =
                await RequestAsync(entity, industry, sourceType, (int)updateCount, semantic, cancellationToken).ConfigureAwait(false);

            foreach (IReadOnlyDictionary<string, object?> value in values)
            {
                if (!pool.TryPeek(out object key))
                {
                    break;
                }

                var fields = new Dictionary<string, object?>(value, StringComparer.Ordinal);
                SystemFieldStamper.Stamp(entity, fields, key, at, RecordAction.Update);
                records.Add(new GeneratedRecord { Action = RecordAction.Update, Key = key, Fields = fields });
            }
        }
        else if (updateCount > 0)
        {
            _logger.LogDebug("Skipping {Count} updates for {Entity}: identity pool is warming up.", updateCount, entity.Key);
        }

        if (deleteCount > 0)
        {
            int retired = 0;
            for (long i = 0; i < deleteCount; i++)
            {
                if (!pool.TryTake(out object key))
                {
                    break;
                }

                var fields = new Dictionary<string, object?>(StringComparer.Ordinal);
                SystemFieldStamper.Stamp(entity, fields, key, at, RecordAction.Delete);
                records.Add(new GeneratedRecord { Action = RecordAction.Delete, Key = key, Fields = fields });
                retired++;
            }

            if (retired < deleteCount)
            {
                _logger.LogDebug("Only retired {Retired} of {Requested} deletes for {Entity}: pool exhausted.",
                    retired, deleteCount, entity.Key);
            }
        }

        return new EntityBatch
        {
            SchemaArea = entity.SchemaArea,
            EntityName = entity.EntityName,
            GeneratedAt = at,
            Records = records
        };
    }

    private async Task<IReadOnlyList<IReadOnlyDictionary<string, object?>>> RequestAsync(
        EntityInfo entity,
        string industry,
        string sourceType,
        int count,
        IReadOnlyList<AttributeInfo> semantic,
        CancellationToken cancellationToken)
    {
        var request = new ValueRequest
        {
            Entity = entity,
            Industry = industry,
            SourceType = sourceType,
            Count = count,
            SemanticAttributes = semantic
        };

        return await _provider.GenerateAsync(request, cancellationToken).ConfigureAwait(false);
    }
}

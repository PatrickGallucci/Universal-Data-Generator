using DataGen.Abstractions;

namespace DataGen.Targets;

/// <summary>
/// The built-in sink registrations. Concrete sinks build the real adapter. This list is the single source of
/// truth for which target types ship in the box, and the model for registering custom sinks through DI.
/// </summary>
public static class DefaultSinks
{
    /// <summary>Returns a fresh list of the built-in registrations.</summary>
    public static IReadOnlyList<ISinkRegistration> All() =>
    [
        new SinkRegistration("JsonFile", SinkKind.Batch, (c, l) => new JsonFileSink(c, l)),
        new SinkRegistration("Console", SinkKind.Streaming, (c, l) => new ConsoleSink(c, l)),
        new SinkRegistration("Null", SinkKind.Batch, (c, l) => new NullSink(c, l)),
        new SinkRegistration("ADLSGen2", SinkKind.Batch, (c, l) => new AdlsGen2Sink(c, l)),
        new SinkRegistration("ADLSGen2Parquet", SinkKind.Batch, (c, l) => new AdlsGen2ParquetSink(c, l)),
        new SinkRegistration("EventHubs", SinkKind.Streaming, (c, l) => new EventHubsSink(c, l)),

        new SinkRegistration("AzureBlobStorage", SinkKind.Batch, (c, l) => new AzureBlobSink(c, l)),
        new SinkRegistration("AzureFiles", SinkKind.Batch, (c, l) => new AzureFilesSink(c, l)),
        new SinkRegistration("AzureDataShare", SinkKind.Batch, (c, l) => new AzureDataShareSink(c, l)),
        new SinkRegistration("OneLakeLakehouse", SinkKind.Batch, (c, l) => new OneLakeLakehouseSink(c, l)),
        new SinkRegistration("AzureSqlDB", SinkKind.Batch, (c, l) => new SqlServerSink(c, l)),
        new SinkRegistration("OneLakeWarehouse", SinkKind.Batch, (c, l) => new SqlServerSink(c, l)),
        new SinkRegistration("PostgreSQL", SinkKind.Batch, (c, l) => new PostgreSqlSink(c, l)),
        new SinkRegistration("AzureCosmosDB", SinkKind.Batch, (c, l) => new CosmosDbSink(c, l)),
        new SinkRegistration("AzureAISearchIndex", SinkKind.Batch, (c, l) => new AiSearchSink(c, l)),
        new SinkRegistration("AzureServiceBus", SinkKind.Streaming, (c, l) => new ServiceBusSink(c, l)),
        Pending("AzureEventGrid", SinkKind.Streaming, "Azure.Messaging.EventGrid"),
        Pending("FabricEventhouse", SinkKind.Streaming, "Microsoft.Azure.Kusto.Ingest"),
        Pending("Dataverse", SinkKind.Batch, "Microsoft.PowerPlatform.Dataverse.Client"),
        Pending("DatabricksUC", SinkKind.Batch, "Databricks SQL Statement Execution API")
    ];

    private static SinkRegistration Pending(string targetType, SinkKind kind, string package)
        => new(targetType, kind, (c, _) => new CloudSinkStub(c, kind, package));
}

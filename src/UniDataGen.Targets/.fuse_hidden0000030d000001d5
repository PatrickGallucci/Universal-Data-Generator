using Azure.Identity;
using Azure.Messaging.ServiceBus;
using DataGen.Abstractions;
using Microsoft.Extensions.Logging;
using Microsoft.Extensions.Logging.Abstractions;

namespace DataGen.Targets;

/// <summary>
/// Streams generated records to an Azure Service Bus queue or topic, one message per record with the action in the
/// application properties. Authentication is Microsoft Entra by default, or a connection string.
/// </summary>
public sealed class ServiceBusSink : ISink
{
    private readonly string? _fullyQualifiedNamespace;
    private readonly string? _connectionString;
    private readonly string _entityName;
    private readonly ILogger _logger;
    private ServiceBusClient? _client;
    private ServiceBusSender? _sender;

    public ServiceBusSink(TargetConfig config, ILogger? logger = null)
    {
        ArgumentNullException.ThrowIfNull(config);
        IReadOnlyDictionary<string, object?> p = config.Properties;
        _entityName = PropertyBag.GetString(p, "entityName")
            ?? PropertyBag.GetString(p, "queue")
            ?? PropertyBag.GetString(p, "topic")
            ?? throw new InvalidOperationException("AzureServiceBus target requires an 'entityName' (queue or topic) property.");
        _connectionString = PropertyBag.GetString(p, "connectionString");
        _fullyQualifiedNamespace = ResolveNamespace(p);
        _logger = logger ?? NullLogger.Instance;
        TargetType = config.TargetType;

        if (_connectionString is null && _fullyQualifiedNamespace is null)
        {
            throw new InvalidOperationException("AzureServiceBus target requires a 'namespace' or 'connectionString' property.");
        }
    }

    public SinkKind Kind => SinkKind.Streaming;

    public string TargetType { get; }

    public Task OpenAsync(CancellationToken cancellationToken)
    {
        _client = _connectionString is { } cs
            ? new ServiceBusClient(cs)
            : new ServiceBusClient(_fullyQualifiedNamespace, new DefaultAzureCredential());
        _sender = _client.CreateSender(_entityName);
        _logger.LogInformation("Service Bus sender opened for {Entity}.", _entityName);
        return Task.CompletedTask;
    }

    public async Task WriteAsync(EntityBatch batch, CancellationToken cancellationToken)
    {
        ArgumentNullException.ThrowIfNull(batch);
        if (_sender is null)
        {
            throw new InvalidOperationException($"{nameof(OpenAsync)} must be called before {nameof(WriteAsync)}.");
        }

        if (batch.Records.Count == 0)
        {
            return;
        }

        using ServiceBusMessageBatch messageBatch = await _sender.CreateMessageBatchAsync(cancellationToken).ConfigureAwait(false);
        int sent = 0;
        var current = messageBatch;

        foreach (GeneratedRecord record in batch.Records)
        {
            var message = new ServiceBusMessage(BinaryData.FromString(NdjsonFormatter.SerializeRecord(record, batch.GeneratedAt)))
            {
                ApplicationProperties = { ["action"] = record.Action.ToString(), ["entity"] = batch.Key }
            };

            if (!current.TryAddMessage(message))
            {
                await _sender.SendMessagesAsync(current, cancellationToken).ConfigureAwait(false);
                sent += current.Count;
                current.Dispose();
                current = await _sender.CreateMessageBatchAsync(cancellationToken).ConfigureAwait(false);
                current.TryAddMessage(message);
            }
        }

        if (current.Count > 0)
        {
            await _sender.SendMessagesAsync(current, cancellationToken).ConfigureAwait(false);
            sent += current.Count;
        }

        if (!ReferenceEquals(current, messageBatch))
        {
            current.Dispose();
        }

        _logger.LogInformation("Streamed {Count} messages for {Entity}.", sent, batch.Key);
    }

    private static string? ResolveNamespace(IReadOnlyDictionary<string, object?> p)
    {
        string? ns = PropertyBag.GetString(p, "namespace");
        if (string.IsNullOrWhiteSpace(ns))
        {
            return null;
        }

        return ns.Contains('.', StringComparison.Ordinal) ? ns : $"{ns}.servicebus.windows.net";
    }

    public async ValueTask DisposeAsync()
    {
        if (_sender is not null)
        {
            await _sender.DisposeAsync().ConfigureAwait(false);
        }

        if (_client is not null)
        {
            await _client.DisposeAsync().ConfigureAwait(false);
        }
    }
}

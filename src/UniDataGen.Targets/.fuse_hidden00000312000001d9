using DataGen.Abstractions;
using Microsoft.Extensions.Logging;

namespace DataGen.Targets;

/// <summary>
/// A convenience <see cref="ISinkFactory"/> that uses the built-in registrations from <see cref="DefaultSinks"/>.
/// Hosts that use dependency injection should call <c>AddDataGenTargets</c> and resolve <see cref="ISinkFactory"/>
/// instead; this type exists for hosts that construct the factory directly, such as the PowerShell module.
/// </summary>
public sealed class SinkFactory : ISinkFactory
{
    private readonly DiSinkFactory _inner;

    public SinkFactory(ILoggerFactory? loggerFactory = null)
        => _inner = new DiSinkFactory(DefaultSinks.All(), loggerFactory);

    /// <inheritdoc />
    public bool CanCreate(string targetType) => _inner.CanCreate(targetType);

    /// <inheritdoc />
    public ISink Create(TargetConfig config) => _inner.Create(config);
}

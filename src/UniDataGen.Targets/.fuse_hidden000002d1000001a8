using System.Globalization;
using System.Net.Http.Headers;
using System.Net.Http.Json;
using System.Text;
using DataGen.Abstractions;
using Microsoft.Extensions.Logging;
using Microsoft.Extensions.Logging.Abstractions;

namespace DataGen.Targets;

/// <summary>
/// Writes generated batches to a Databricks Unity Catalog table through the SQL Statement Execution REST API.
/// New records insert as a single multi-row statement; Update and Delete run per-row statements by the configured
/// key column. Authentication is a Databricks personal access token. The target table must already exist.
/// </summary>
public sealed class DatabricksUcSink : ISink
{
    private readonly string _workspaceUrl;
    private readonly string _warehouseId;
    private readonly string _catalog;
    private readonly string _schema;
    private readonly string _table;
    private readonly string _token;
    private readonly string? _keyColumn;
    private readonly ILogger _logger;
    private HttpClient? _http;

    public DatabricksUcSink(TargetConfig config, ILogger? logger = null)
    {
        ArgumentNullException.ThrowIfNull(config);
        IReadOnlyDictionary<string, object?> p = config.Properties;
        _workspaceUrl = (PropertyBag.GetString(p, "workspaceUrl") ?? throw new InvalidOperationException("DatabricksUC target requires a 'workspaceUrl' property.")).TrimEnd('/');
        _warehouseId = PropertyBag.GetString(p, "warehouseId") ?? throw new InvalidOperationException("DatabricksUC target requires a 'warehouseId' property.");
        _catalog = PropertyBag.GetString(p, "catalog") ?? throw new InvalidOperationException("DatabricksUC target requires a 'catalog' property.");
        _schema = PropertyBag.GetString(p, "schema") ?? throw new InvalidOperationException("DatabricksUC target requires a 'schema' property.");
        _table = PropertyBag.GetString(p, "table") ?? throw new InvalidOperationException("DatabricksUC target requires a 'table' property.");
        _token = PropertyBag.GetString(p, "token") ?? Environment.GetEnvironmentVariable("DATABRICKS_TOKEN")
            ?? throw new InvalidOperationException("DatabricksUC target requires a 'token' property or DATABRICKS_TOKEN.");
        _keyColumn = PropertyBag.GetString(p, "keyColumn");
        _logger = logger ?? NullLogger.Instance;
        TargetType = config.TargetType;
    }

    public SinkKind Kind => SinkKind.Batch;

    public string TargetType { get; }

    public Task OpenAsync(CancellationToken cancellationToken)
    {
        _http = new HttpClient { BaseAddress = new Uri(_workspaceUrl) };
        _http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", _token);
        _logger.LogInformation("Databricks UC sink ready: {Catalog}.{Schema}.{Table}.", _catalog, _schema, _table);
        return Task.CompletedTask;
    }

    public async Task WriteAsync(EntityBatch batch, CancellationToken cancellationToken)
    {
        ArgumentNullException.ThrowIfNull(batch);
        if (_http is null)
        {
            throw new InvalidOperationException($"{nameof(OpenAsync)} must be called before {nameof(WriteAsync)}.");
        }

        if (batch.Records.Count == 0)
        {
            return;
        }

        string fullName = $"`{_catalog}`.`{_schema}`.`{_table}`";

        var inserts = batch.Records.Where(r => r.Action == RecordAction.New).ToList();
        if (inserts.Count > 0)
        {
            await ExecuteAsync(BuildInsert(fullName, inserts), cancellationToken).ConfigureAwait(false);
        }

        if (_keyColumn is not null)
        {
            foreach (GeneratedRecord record in batch.Records.Where(r => r.Action == RecordAction.Update))
            {
                await ExecuteAsync(BuildUpdate(fullName, record), cancellationToken).ConfigureAwait(false);
            }

            foreach (GeneratedRecord record in batch.Records.Where(r => r.Action == RecordAction.Delete))
            {
                await ExecuteAsync($"DELETE FROM {fullName} WHERE `{_keyColumn}` = {Literal(record.Key)};", cancellationToken).ConfigureAwait(false);
            }
        }

        _logger.LogInformation("Applied {Count} rows to {Table}.", batch.Records.Count, fullName);
    }

    private string BuildInsert(string fullName, List<GeneratedRecord> records)
    {
        var columns = records[0].Fields.Keys.ToList();
        string colList = string.Join(", ", columns.Select(c => $"`{c}`"));
        var rows = records.Select(r => "(" + string.Join(", ", columns.Select(c => Literal(r.Fields[c]))) + ")");
        return $"INSERT INTO {fullName} ({colList}) VALUES {string.Join(", ", rows)};";
    }

    private string BuildUpdate(string fullName, GeneratedRecord record)
    {
        var setColumns = record.Fields.Keys.Where(c => !c.Equals(_keyColumn, StringComparison.OrdinalIgnoreCase));
        string setClause = string.Join(", ", setColumns.Select(c => $"`{c}` = {Literal(record.Fields[c])}"));
        return $"UPDATE {fullName} SET {setClause} WHERE `{_keyColumn}` = {Literal(record.Key)};";
    }

    private async Task ExecuteAsync(string statement, CancellationToken cancellationToken)
    {
        var payload = new
        {
            warehouse_id = _warehouseId,
            catalog = _catalog,
            schema = _schema,
            statement,
            wait_timeout = "30s"
        };

        using HttpResponseMessage response = await _http!.PostAsJsonAsync("/api/2.0/sql/statements", payload, cancellationToken).ConfigureAwait(false);
        if (!response.IsSuccessStatusCode)
        {
            string body = await response.Content.ReadAsStringAsync(cancellationToken).ConfigureAwait(false);
            _logger.LogError("Databricks statement failed: {Status} {Body}.", (int)response.StatusCode, body);
            response.EnsureSuccessStatusCode();
        }
    }

    private static string Literal(object? value) => value switch
    {
        null => "NULL",
        bool b => b ? "true" : "false",
        sbyte or byte or short or ushort or int or uint or long or ulong => Convert.ToInt64(value, CultureInfo.InvariantCulture).ToString(CultureInfo.InvariantCulture),
        float or double or decimal => Convert.ToDecimal(value, CultureInfo.InvariantCulture).ToString(CultureInfo.InvariantCulture),
        DateTime dt => $"'{dt.ToUniversalTime():yyyy-MM-dd HH:mm:ss}'",
        DateTimeOffset dto => $"'{dto.UtcDateTime:yyyy-MM-dd HH:mm:ss}'",
        _ => "'" + value.ToString()!.Replace("'", "''", StringComparison.Ordinal) + "'"
    };

    public ValueTask DisposeAsync()
    {
        _http?.Dispose();
        return ValueTask.CompletedTask;
    }
}

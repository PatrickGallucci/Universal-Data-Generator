using DataGen.Abstractions;

namespace DataGen.Targets;

/// <summary>
/// Creates sinks for the workbook Storage targets. Built-in sinks (JsonFile, Console, Null) are concrete;
/// the cloud targets resolve to a scaffolded stub that names the package needed to finish each adapter.
/// </summary>
public sealed class SinkFactory : ISinkFactory
{
    private static readonly Dictionary<string, (SinkKind Kind, string Package)> CloudTargets =
        new(StringComparer.OrdinalIgnoreCase)
        {
            ["ADLSGen2"] = (SinkKind.Batch, "Azure.Storage.Files.DataLake"),
            ["AzureAISearchIndex"] = (SinkKind.Batch, "Azure.Search.Documents"),
            ["AzureBlobStorage"] = (SinkKind.Batch, "Azure.Storage.Blobs"),
            ["AzureCosmosDB"] = (SinkKind.Batch, "Microsoft.Azure.Cosmos"),
            ["AzureDataShare"] = (SinkKind.Batch, "Azure.ResourceManager.DataShare"),
            ["AzureEventGrid"] = (SinkKind.Streaming, "Azure.Messaging.EventGrid"),
            ["AzureFiles"] = (SinkKind.Batch, "Azure.Storage.Files.Shares"),
            ["AzureServiceBus"] = (SinkKind.Streaming, "Azure.Messaging.ServiceBus"),
            ["AzureSqlDB"] = (SinkKind.Batch, "Microsoft.Data.SqlClient"),
            ["DatabricksUC"] = (SinkKind.Batch, "Databricks SQL connector"),
            ["Dataverse"] = (SinkKind.Batch, "Microsoft.PowerPlatform.Dataverse.Client"),
            ["EventHubs"] = (SinkKind.Streaming, "Azure.Messaging.EventHubs"),
            ["FabricEventhouse"] = (SinkKind.Streaming, "Azure.Data.Kusto / Kusto.Ingest"),
            ["OneLakeLakehouse"] = (SinkKind.Batch, "Microsoft.Fabric / Delta on ADLS"),
            ["OneLakeWarehouse"] = (SinkKind.Batch, "Microsoft.Data.SqlClient (Fabric DW)"),
            ["PostgreSQL"] = (SinkKind.Batch, "Npgsql")
        };

    /// <inheritdoc />
    public bool CanCreate(string targetType)
        => targetType is "JsonFile" or "Console" or "Null" || CloudTargets.ContainsKey(targetType);

    /// <inheritdoc />
    public ISink Create(TargetConfig config)
    {
        ArgumentNullException.ThrowIfNull(config);

        return config.TargetType switch
        {
            "JsonFile" => new JsonFileSink(config),
            "Console" => new ConsoleSink(config),
            "Null" => new NullSink(config),
            "ADLSGen2" => new AdlsGen2Sink(config),
            _ when CloudTargets.TryGetValue(config.TargetType, out var meta)
                => new CloudSinkStub(config, meta.Kind, meta.Package),
            _ => throw new NotSupportedException($"Unknown target type '{config.TargetType}'.")
        };
    }
}

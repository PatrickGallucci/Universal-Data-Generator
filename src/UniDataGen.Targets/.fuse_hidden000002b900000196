using DataGen.Abstractions;
using Microsoft.Extensions.Logging;

namespace DataGen.Targets;

/// <summary>
/// Lands snapshot data for an Azure Data Share into the share's backing blob container, partitioned by dataset.
/// Azure Data Share publishes datasets that point at storage; creating the share, dataset, and invitation is a
/// management-plane setup step. This sink writes the data that a blob- or ADLS-backed dataset shares, as NDJSON.
/// </summary>
public sealed class AzureDataShareSink : ISink
{
    private readonly BlobUploader _uploader;
    private readonly string _datasetPrefix;

    public AzureDataShareSink(TargetConfig config, ILogger? logger = null)
    {
        ArgumentNullException.ThrowIfNull(config);
        IReadOnlyDictionary<string, object?> p = config.Properties;
        _uploader = new BlobUploader(
            AdlsUploader.ResolveAccountName(p),
            PropertyBag.GetString(p, "container") ?? throw new InvalidOperationException("AzureDataShare target requires a backing 'container' property."),
            config.Authentication,
            PropertyBag.GetString(p, "accountKey"),
            logger);
        string dataset = PropertyBag.GetString(p, "datasetName") ?? "dataset";
        string? path = PropertyBag.GetString(p, "path");
        _datasetPrefix = string.IsNullOrWhiteSpace(path) ? dataset : $"{path.Trim('/')}/{dataset}";
        TargetType = config.TargetType;
    }

    public SinkKind Kind => SinkKind.Batch;

    public string TargetType { get; }

    public Task OpenAsync(CancellationToken cancellationToken) => _uploader.OpenAsync(cancellationToken);

    public async Task WriteAsync(EntityBatch batch, CancellationToken cancellationToken)
    {
        ArgumentNullException.ThrowIfNull(batch);
        if (batch.Records.Count == 0)
        {
            return;
        }

        string directory = AdlsPath.BuildDirectory(_datasetPrefix, batch.SchemaArea, batch.EntityName, batch.GeneratedAt);
        string name = $"{directory}/{AdlsPath.BuildFileName(batch.EntityName, batch.GeneratedAt)}";
        await _uploader.UploadAsync(name, NdjsonFormatter.SerializeToUtf8(batch), cancellationToken).ConfigureAwait(false);
    }

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}

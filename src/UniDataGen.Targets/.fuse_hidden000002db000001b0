using DataGen.Abstractions;
using Microsoft.Extensions.Logging;
using Microsoft.Extensions.Logging.Abstractions;
using Microsoft.PowerPlatform.Dataverse.Client;
using Microsoft.Xrm.Sdk;

namespace DataGen.Targets;

/// <summary>
/// Writes generated records to a Microsoft Dataverse table. New creates, Update updates by id, and Delete removes
/// by id. Primitive field values map to columns with matching logical names; complex columns such as lookups and
/// option sets are skipped. Authentication is a managed identity or a client secret. The table must already exist.
/// </summary>
public sealed class DataverseSink : ISink
{
    private readonly string _connectionString;
    private readonly string _table;
    private readonly ILogger _logger;
    private ServiceClient? _client;

    public DataverseSink(TargetConfig config, ILogger? logger = null)
    {
        ArgumentNullException.ThrowIfNull(config);
        IReadOnlyDictionary<string, object?> p = config.Properties;
        _table = PropertyBag.GetString(p, "table") ?? throw new InvalidOperationException("Dataverse target requires a 'table' property.");
        _connectionString = BuildConnectionString(config);
        _logger = logger ?? NullLogger.Instance;
        TargetType = config.TargetType;
    }

    public SinkKind Kind => SinkKind.Batch;

    public string TargetType { get; }

    public Task OpenAsync(CancellationToken cancellationToken)
    {
        _client = new ServiceClient(_connectionString);
        if (!_client.IsReady)
        {
            throw new InvalidOperationException($"Dataverse connection failed: {_client.LastError}");
        }

        _logger.LogInformation("Dataverse client ready for table {Table}.", _table);
        return Task.CompletedTask;
    }

    public async Task WriteAsync(EntityBatch batch, CancellationToken cancellationToken)
    {
        ArgumentNullException.ThrowIfNull(batch);
        if (_client is null)
        {
            throw new InvalidOperationException($"{nameof(OpenAsync)} must be called before {nameof(WriteAsync)}.");
        }

        if (batch.Records.Count == 0)
        {
            return;
        }

        int written = 0;
        foreach (GeneratedRecord record in batch.Records)
        {
            if (record.Key is not Guid id)
            {
                continue; // Dataverse keys are GUIDs; the engine mints GUID keys.
            }

            if (record.Action == RecordAction.Delete)
            {
                await _client.DeleteAsync(_table, id, cancellationToken).ConfigureAwait(false);
                written++;
                continue;
            }

            var entity = new Entity(_table, id);
            foreach (KeyValuePair<string, object?> field in record.Fields)
            {
                if (field.Value is { } value && IsPrimitive(value) && !IsKey(value, id))
                {
                    entity[field.Key] = Normalize(value);
                }
            }

            if (record.Action == RecordAction.New)
            {
                await _client.CreateAsync(entity, cancellationToken).ConfigureAwait(false);
            }
            else
            {
                await _client.UpdateAsync(entity, cancellationToken).ConfigureAwait(false);
            }

            written++;
        }

        _logger.LogInformation("Applied {Count} rows to Dataverse table {Table}.", written, _table);
    }

    private static bool IsKey(object value, Guid id) => value is Guid g && g == id;

    private static bool IsPrimitive(object value) => value is string or bool or int or long or short or byte
        or double or float or decimal or DateTime or DateTimeOffset or Guid;

    private static object Normalize(object value) => value switch
    {
        DateTimeOffset dto => dto.UtcDateTime,
        _ => value
    };

    private static string BuildConnectionString(TargetConfig config)
    {
        IReadOnlyDictionary<string, object?> p = config.Properties;
        if (PropertyBag.GetString(p, "connectionString") is { } cs)
        {
            return cs;
        }

        string url = PropertyBag.GetString(p, "environmentUrl") ?? throw new InvalidOperationException("Dataverse target requires an 'environmentUrl' property.");
        string? clientId = PropertyBag.GetString(p, "clientId");
        string? clientSecret = PropertyBag.GetString(p, "clientSecret");
        if (!string.IsNullOrWhiteSpace(clientId) && !string.IsNullOrWhiteSpace(clientSecret))
        {
            return $"AuthType=ClientSecret;Url={url};ClientId={clientId};ClientSecret={clientSecret}";
        }

        return clientId is { Length: > 0 }
            ? $"AuthType=ManagedIdentity;Url={url};ClientId={clientId}"
            : $"AuthType=ManagedIdentity;Url={url}";
    }

    public ValueTask DisposeAsync()
    {
        _client?.Dispose();
        return ValueTask.CompletedTask;
    }
}

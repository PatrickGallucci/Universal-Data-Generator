using DataGen.Abstractions;
using Microsoft.Extensions.Logging;
using Microsoft.Extensions.Logging.Abstractions;

namespace DataGen.Targets;

/// <summary>
/// Writes each batch as newline-delimited JSON to a directory, one file per entity per batch. The record
/// envelope carries the action so downstream readers can apply New, Update, and Delete as change events.
/// This is the dependency-free reference sink and lets the whole pipeline run offline.
/// </summary>
public sealed class JsonFileSink : ISink
{
    private readonly string _directory;
    private readonly ILogger _logger;

    public JsonFileSink(TargetConfig config, ILogger? logger = null)
    {
        ArgumentNullException.ThrowIfNull(config);
        _directory = PropertyBag.GetString(config.Properties, "directory") ?? "./out";
        _logger = logger ?? NullLogger.Instance;
        TargetType = config.TargetType;
    }

    public SinkKind Kind => SinkKind.Batch;

    public string TargetType { get; }

    public Task OpenAsync(CancellationToken cancellationToken)
    {
        Directory.CreateDirectory(_directory);
        _logger.LogInformation("JsonFile sink open at {Directory}.", _directory);
        return Task.CompletedTask;
    }

    public async Task WriteAsync(EntityBatch batch, CancellationToken cancellationToken)
    {
        ArgumentNullException.ThrowIfNull(batch);
        if (batch.Records.Count == 0)
        {
            return;
        }

        string file = Path.Combine(_directory, $"{batch.EntityName}-{batch.GeneratedAt:yyyyMMddHHmmssfff}.ndjson");
        string content = NdjsonFormatter.Serialize(batch);
        await File.AppendAllTextAsync(file, content, cancellationToken).ConfigureAwait(false);
        _logger.LogInformation("Wrote {Count} records for {Entity} to {File} ({Bytes} bytes).",
            batch.Records.Count, batch.Key, file, content.Length);
    }

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}

/// <summary>Writes a one-line summary of each batch to the console and the logger. Useful for smoke tests.</summary>
public sealed class ConsoleSink : ISink
{
    private readonly ILogger _logger;

    public ConsoleSink(TargetConfig config, ILogger? logger = null)
    {
        _logger = logger ?? NullLogger.Instance;
        TargetType = config.TargetType;
    }

    public SinkKind Kind => SinkKind.Streaming;

    public string TargetType { get; }

    public Task OpenAsync(CancellationToken cancellationToken) => Task.CompletedTask;

    public Task WriteAsync(EntityBatch batch, CancellationToken cancellationToken)
    {
        int news = batch.Records.Count(r => r.Action == RecordAction.New);
        int updates = batch.Records.Count(r => r.Action == RecordAction.Update);
        int deletes = batch.Records.Count(r => r.Action == RecordAction.Delete);
        Console.WriteLine($"[{batch.GeneratedAt:O}] {batch.Key}: {news} new, {updates} update, {deletes} delete");
        _logger.LogInformation("{Entity}: {New} new, {Update} update, {Delete} delete.", batch.Key, news, updates, deletes);
        return Task.CompletedTask;
    }

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}

/// <summary>Discards all writes. Useful for load testing the engine without a real target.</summary>
public sealed class NullSink : ISink
{
    public NullSink(TargetConfig config, ILogger? logger = null) => TargetType = config.TargetType;

    public SinkKind Kind => SinkKind.Batch;

    public string TargetType { get; }

    public Task OpenAsync(CancellationToken cancellationToken) => Task.CompletedTask;

    public Task WriteAsync(EntityBatch batch, CancellationToken cancellationToken) => Task.CompletedTask;

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}

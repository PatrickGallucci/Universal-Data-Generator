        header.Controls.Add(_txtWorkbook);
        header.Controls.Add(_btnLoad);
        header.Controls.Add(new Label { Text = "Industry:", AutoSize = true, Padding = new Padding(8, 6, 0, 0) });
        header.Controls.Add(_cmbIndustry);
        header.Controls.Add(new Label { Text = "Source type:", AutoSize = true, Padding = new Padding(8, 6, 0, 0) });
        header.Controls.Add(_cmbSourceType);
        header.Controls.Add(_txtEndpoint);
        header.Controls.Add(_txtDeployment);
        header.Controls.Add(_txtAppInsights);
        header.Controls.Add(new Label { Text = "Locale:", AutoSize = true, Padding = new Padding(8, 6, 0, 0) });
        header.Controls.Add(_cmbLocale);

        foreach (BatchUnit unit in Enum.GetValues<BatchUnit>())
        {
            _cmbFreqUnit.Items.Add(unit);
        }

        _cmbFreqUnit.SelectedItem = BatchUnit.Day;

        foreach (LocaleInfo info in LocaleCatalog.Locales)
        {
            _cmbLocale.Items.Add(info.Locale);
            _cmbEntityLocale.Items.Add(info.Locale);
        }

        _cmbLocale.SelectedItem = LocaleCatalog.DefaultLocale;
        _cmbEntityLocale.Items.Insert(0, InheritLocale);
        _cmbEntityLocale.SelectedItem = InheritLocale;

        SetupWeightsGrid();
        SetupRatesGrid();
        SetupBoostsGrid();
        foreach (string t in TargetTypes)
        {
            _clbTargets.Items.Add(t, t == "JsonFile");
        }

        // Left: entity picker
        var pickButtons = new FlowLayoutPanel { FlowDirection = FlowDirection.TopDown, Width = 90, Height = 360 };
        pickButtons.Controls.Add(_btnAdd);
        pickButtons.Controls.Add(_btnRemove);

        var leftInner = new FlowLayoutPanel { Dock = DockStyle.Fill, AutoScroll = true };
        var allPanel = new FlowLayoutPanel { FlowDirection = FlowDirection.TopDown, Width = 240, Height = 400 };
        allPanel.Controls.Add(new Label { Text = "Catalog entities", AutoSize = true });
        allPanel.Controls.Add(_txtFilter);
        allPanel.Controls.Add(_lstAll);
        var selPanel = new FlowLayoutPanel { FlowDirection = FlowDirection.TopDown, Width = 240, Height = 400 };
        selPanel.Controls.Add(new Label { Text = "Selected entities", AutoSize = true });
        selPanel.Controls.Add(_lstSelected);
        leftInner.Controls.Add(allPanel);
        leftInner.Controls.Add(pickButtons);
        leftInner.Controls.Add(selPanel);

        // Right: editor

    private void SetupWeightsGrid()
    {
        _gridWeights.Columns.Clear();
        foreach (string h in DayPartHeaders)
        {
            _gridWeights.Columns.Add(h, h);
        }

        _gridWeights.Rows.Add();
        _gridWeights.Rows.Add();
        _gridWeights.Rows.Add();
        _gridWeights.Rows[0].HeaderCell.Value = "Whole week";
        _gridWeights.Rows[1].HeaderCell.Value = "Weekday";
        _gridWeights.Rows[2].HeaderCell.Value = "Weekend";
    }

    private void SetupRatesGrid()
    {
        _gridRates.Columns.Clear();
        foreach (string h in ActionHeaders)
        {
            _gridRates.Columns.Add(h, h);
        }

        _gridRates.Rows.Add();
        _gridRates.Rows.Add();
        _gridRates.Rows[0].HeaderCell.Value = "Real-time / hour";
        _gridRates.Rows[1].HeaderCell.Value = "Batch / batch";
    }

    private void SetupBoostsGrid()
    {
        _gridBoosts.Columns.Clear();
        _gridBoosts.Columns.Add("Date", "Date (yyyy-MM-dd)");
        _gridBoosts.Columns.Add("BoostPercent", "Shoulder %");
        _gridBoosts.Columns.Add("DaysBefore", "Days before");
        _gridBoosts.Columns.Add("DaysAfter", "Days after");
        _gridBoosts.Columns.Add("BoostPercentOnDate", "Peak %");
        foreach (DataGridViewColumn col in _gridBoosts.Columns)
        {
            col.AutoSizeMode = DataGridViewAutoSizeColumnMode.Fill;
        }
    }

    private void WireEvents()
    {
        _btnLoad.Click += (_, _) => LoadWorkbook();
        _txtFilter.TextChanged += (_, _) => ApplyFilter();
        _btnAdd.Click += (_, _) => AddSelectedEntities();
        _btnRemove.Click += (_, _) => RemoveSelectedEntity();
        _lstSelected.SelectedIndexChanged += (_, _) => BindCurrent();

        _rbRealTime.CheckedChanged += (_, _) => SaveEditor();
        _rbBatch.CheckedChanged += (_, _) => SaveEditor();
        _rbWholeWeek.CheckedChanged += (_, _) => SaveEditor();
        _rbSplit.CheckedChanged += (_, _) => SaveEditor();
        _gridWeights.CellEndEdit += (_, _) => SaveEditor();
        _gridRates.CellEndEdit += (_, _) => SaveEditor();
        _numFreqCount.ValueChanged += (_, _) => SaveEditor();
        _cmbFreqUnit.SelectedIndexChanged += (_, _) => SaveEditor();
        _cmbEntityLocale.SelectedIndexChanged += (_, _) => SaveEditor();
        _gridBoosts.CellEndEdit += (_, _) => { SaveEditor(); UpdateBoostPreview(); };
        _gridBoosts.SelectionChanged += (_, _) => UpdateBoostPreview();
        _btnRemoveBoost.Click += (_, _) => RemoveBoostRow();

        _btnValidate.Click += (_, _) => DoValidate();
        _btnSave.Click += (_, _) => DoSave();
        _btnRun.Click += async (_, _) => await DoRunAsync();
        _btnStop.Click += (_, _) => _runCts?.Cancel();
    }

    private void LoadWorkbook()
    {
        using var dialog = new OpenFileDialog { Filter = "Excel workbook (*.xlsx)|*.xlsx" };
        if (dialog.ShowDialog(this) != DialogResult.OK)
        {
            return;
        }

        try
        {
            _txtWorkbook.Text = dialog.FileName;
            Cursor = Cursors.WaitCursor;
            _catalog = new WorkbookCatalogReader(_loggerFactory.CreateLogger<WorkbookCatalogReader>()).Read(dialog.FileName);

            _cmbIndustry.Items.Clear();
            foreach (IndustryInfo industry in _catalog.Industries)
            {
                _cmbIndustry.Items.Add(industry.Name);
            }

            _cmbSourceType.Items.Clear();
            foreach (SourceTypeInfo source in _catalog.SourceTypes)
            {
                _cmbSourceType.Items.Add(source.Code);
            }

            ApplyFilter();
            _btnRun.Enabled = true;
            Log($"Loaded catalog: {_catalog.Industries.Count} industries, {_catalog.SourceTypes.Count} source types, {_catalog.Entities.Count} entities.");
        }
        catch (Exception ex)
        {
            MessageBox.Show(this, ex.Message, "Load failed", MessageBoxButtons.OK, MessageBoxIcon.Error);
        }
        finally
        {
            Cursor = Cursors.Default;
        }
    }

    private void ApplyFilter()
    {
        if (_catalog is null)
        {
            return;
        }

        string filter = _txtFilter.Text.Trim();
        _lstAll.BeginUpdate();
        _lstAll.Items.Clear();
        IEnumerable<EntityInfo> matches = _catalog.Entities
            .Where(e => filter.Length == 0 || e.EntityName.Contains(filter, StringComparison.OrdinalIgnoreCase))
            .Take(2000);
        foreach (EntityInfo entity in matches)
        {
            _lstAll.Items.Add(entity.Key);
        }

        _lstAll.EndUpdate();
    }

    private void AddSelectedEntities()
    {
        foreach (object? item in _lstAll.SelectedItems)
        {
            if (item is not string key || _selected.ContainsKey(key))
            {
                continue;
            }

            string[] parts = key.Split('/', 2);
            var vm = new EntityProfileVm { SchemaArea = parts[0], EntityName = parts[1] };
            _selected[key] = vm;
            _lstSelected.Items.Add(key);
        }
    }

    private void RemoveSelectedEntity()
    {
        if (_lstSelected.SelectedItem is not string key)
        {
            return;
        }

        _selected.Remove(key);
        _lstSelected.Items.Remove(key);
        _current = null;
        SetEditorEnabled(false);
    }

    private void BindCurrent()
    {
        if (_lstSelected.SelectedItem is not string key || !_selected.TryGetValue(key, out EntityProfileVm? vm))
        {
            SetEditorEnabled(false);
            return;
        }

        _current = vm;
        _binding = true;
        SetEditorEnabled(true);

        _rbRealTime.Checked = vm.Mode == GenerationMode.RealTime;
        _rbBatch.Checked = vm.Mode == GenerationMode.Batch;
        _rbWholeWeek.Checked = vm.Split == ScheduleSplit.WholeWeek;
        _rbSplit.Checked = vm.Split == ScheduleSplit.WeekdayWeekend;

        WriteRow(_gridWeights, 0, vm.Week);
        WriteRow(_gridWeights, 1, vm.Weekday);
        WriteRow(_gridWeights, 2, vm.Weekend);
        WriteRow(_gridRates, 0, vm.RealtimePerHour);
        WriteRow(_gridRates, 1, vm.BatchPerBatch);
        _numFreqCount.Value = Math.Clamp(vm.BatchFrequencyCount, 1, 100000);
        _cmbFreqUnit.SelectedItem = vm.BatchFrequencyUnit;
        _cmbEntityLocale.SelectedItem = vm.Locale ?? InheritLocale;

        _gridBoosts.Rows.Clear();
        foreach (BoostDate b in vm.Boosts)
        {
            _gridBoosts.Rows.Add(b.Date.ToString("yyyy-MM-dd"), b.BoostPercent, b.DaysBefore, b.DaysAfter, b.BoostPercentOnDate);
        }

        _binding = false;
        UpdateBoostPreview();
    }

    private void SaveEditor()
    {
        if (_binding || _current is null)
        {
            return;
        }

        _current.Mode = _rbRealTime.Checked ? GenerationMode.RealTime : GenerationMode.Batch;
        _current.Split = _rbSplit.Checked ? ScheduleSplit.WeekdayWeekend : ScheduleSplit.WholeWeek;
        _current.Week = ReadRow(_gridWeights, 0, 4);
        _current.Weekday = ReadRow(_gridWeights, 1, 4);
        _current.Weekend = ReadRow(_gridWeights, 2, 4);
        _current.RealtimePerHour = ReadRow(_gridRates, 0, 3);
        _current.BatchPerBatch = ReadRow(_gridRates, 1, 3);
        _current.BatchFrequencyCount = (int)_numFreqCount.Value;
        _current.BatchFrequencyUnit = _cmbFreqUnit.SelectedItem is BatchUnit u ? u : BatchUnit.Day;
        _current.Locale = _cmbEntityLocale.SelectedItem is string sel && sel != InheritLocale ? sel : null;

        _current.Boosts.Clear();
        foreach (DataGridViewRow row in _gridBoosts.Rows)
        {
            if (row.IsNewRow || row.Cells[0].Value is null)
            {
                continue;
            }

            if (TryReadBoost(row, out BoostDate boost))
            {
                _current.Boosts.Add(boost);
            }
        }
    }

    private static bool TryReadBoost(DataGridViewRow row, out BoostDate boost)
    {
        boost = default!;
        if (!DateOnly.TryParse(row.Cells[0].Value?.ToString(), out DateOnly date))
        {
            return false;
        }

        double pct = ToDouble(row.Cells[1].Value);
        int before = (int)ToDouble(row.Cells[2].Value);
        int after = (int)ToDouble(row.Cells[3].Value);
        double peak = ToDouble(row.Cells[4].Value);
        boost = new BoostDate(date, pct, before, after, peak);
        return true;
    }

    private void UpdateBoostPreview()
    {
        if (_gridBoosts.CurrentRow is { IsNewRow: false } row && TryReadBoost(row, out BoostDate boost))
        {
            _boostPreview.SetBoost(boost);
        }
        else
        {
            _boostPreview.SetBoost(null);
        }
    }

    private void RemoveBoostRow()
    {
        if (_gridBoosts.CurrentRow is { IsNewRow: false } row)
        {
            _gridBoosts.Rows.Remove(row);
            SaveEditor();
            UpdateBoostPreview();
        }
    }

    private void DoValidate()
    {
        if (BuildConfig() is not { } config || _catalog is null)
        {
            return;
        }

        ValidationResult result = new RunConfigurationValidator(_loggerFactory.CreateLogger<RunConfigurationValidator>()).Validate(config, _catalog);
        if (result.IsValid)
        {
            Log("Validation passed.");
        }
        else
        {
            Log("Validation failed:");
            foreach (string error in result.Errors)
            {
                Log("  - " + error);
            }
        }
    }

    private void DoSave()
    {
        if (BuildConfig() is not { } config)
        {
            return;
        }

        using var dialog = new SaveFileDialog { Filter = "JSON (*.json)|*.json", FileName = "run-config.json" };
        if (dialog.ShowDialog(this) != DialogResult.OK)
        {
            return;
        }

        File.WriteAllText(dialog.FileName, new RunConfigurationLoader().ToJson(config));
        Log($"Saved run configuration to {dialog.FileName}.");
    }

    private async Task DoRunAsync()
    {
        if (_catalog is null || BuildConfig() is not { } config)
        {
            return;
        }

        ValidationResult result = new RunConfigurationValidator(_loggerFactory.CreateLogger<RunConfigurationValidator>()).Validate(config, _catalog);
        if (!result.IsValid)
        {
            DoValidate();
            return;
        }

        string? aiConnection = string.IsNullOrWhiteSpace(_txtAppInsights.Text) ? null : _txtAppInsights.Text.Trim();
        _loggerFactory = AppInsightsLogging.CreateFactory(aiConnection, LogLevel.Information, b => b.AddDelegate(Log));

        IValueProvider provider = string.IsNullOrWhiteSpace(_txtEndpoint.Text)
            ? new OfflineValueProvider(config.Run.Industry)
            : new FoundryValueProvider(config.Run.Foundry, logger: _loggerFactory.CreateLogger<FoundryValueProvider>());

        var orchestrator = new GenerationOrchestrator(_catalog, provider, new SinkFactory(_loggerFactory), _loggerFactory);
        _runCts = new CancellationTokenSource();
        _btnRun.Enabled = false;
        _btnStop.Enabled = true;
        Log("Run started. Tick interval 2s. Press Stop to end.");

        try
        {
            await orchestrator.RunAsync(config, TimeSpan.FromSeconds(2), _runCts.Token);
        }
        catch (OperationCanceledException)
        {
            Log("Run stopped.");
        }
        catch (Exception ex)
        {
            Log("Run error: " + ex.Message);
        }
        finally
        {
            _btnRun.Enabled = true;
            _btnStop.Enabled = false;
            (provider as IDisposable)?.Dispose();
        }
    }

    private RunConfiguration? BuildConfig()
    {
        if (_catalog is null)
        {
            MessageBox.Show(this, "Load the workbook first.", "No catalog", MessageBoxButtons.OK, MessageBoxIcon.Information);
            return null;
        }

        SaveEditor();

        if (_cmbIndustry.SelectedItem is not string industry || _cmbSourceType.SelectedItem is not string sourceType)
        {
            MessageBox.Show(this, "Pick an industry and a source type.", "Missing selection", MessageBoxButtons.OK, MessageBoxIcon.Information);
            return null;
        }

        var foundry = new FoundrySettings(
            _txtEndpoint.Text.Trim(),
            string.IsNullOrWhiteSpace(_txtDeployment.Text) ? "gpt-4.1" : _txtDeployment.Text.Trim());

        var targets = new List<TargetConfig>();
        foreach (object? checkedItem in _clbTargets.CheckedItems)
        {
            if (checkedItem is not string type)
            {
                continue;
            }

            IReadOnlyDictionary<string, object?> properties = type == "JsonFile"
                ? new Dictionary<string, object?> { ["directory"] = _txtJsonDir.Text.Trim() }
                : new Dictionary<string, object?>();
            targets.Add(new TargetConfig { TargetType = type, Name = type.ToLowerInvariant(), Enabled = true, Properties = properties });
        }

        return new RunConfiguration
        {
            Run = new RunHeader(industry, sourceType, foundry),
            Entities = _selected.Values.Select(v => v.ToProfile()).ToList(),
            Targets = targets
        };
    }

    private void SetEditorEnabled(bool enabled)
    {
        foreach (Control control in new Control[]
        {
            _rbRealTime, _rbBatch, _rbWholeWeek, _rbSplit, _gridWeights, _gridRates,
            _numFreqCount, _cmbFreqUnit, _cmbEntityLocale, _gridBoosts, _btnRemoveBoost
        })
        {
            control.Enabled = enabled;
        }
    }

    private static void WriteRow(DataGridView grid, int rowIndex, double[] values)
    {
        for (int i = 0; i < values.Length && i < grid.Columns.Count; i++)
        {
            grid.Rows[rowIndex].Cells[i].Value = values[i];
        }
    }

    private static double[] ReadRow(DataGridView grid, int rowIndex, int count)
    {
        var values = new double[count];
        for (int i = 0; i < count; i++)
        {
            values[i] = ToDouble(grid.Rows[rowIndex].Cells[i].Value);
        }

        return values;
    }

    private static double ToDouble(object? value)
        => value is not null && double.TryParse(value.ToString(), out double d) ? d : 0.0;

    private void Log(string message)
    {
        if (InvokeRequired)
        {
            BeginInvoke(() => Log(message));
            return;
        }

        _txtLog.AppendText($"{DateTime.Now:HH:mm:ss}  {message}{Environment.NewLine}");
    }
}

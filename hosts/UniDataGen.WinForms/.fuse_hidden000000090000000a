        var modeRow = new FlowLayoutPanel { AutoSize = true };
        modeRow.Controls.Add(new Label { Text = "Mode:", AutoSize = true, Padding = new Padding(0, 4, 0, 0) });
        modeRow.Controls.Add(_rbRealTime);
        modeRow.Controls.Add(_rbBatch);
        modeRow.Controls.Add(new Label { Text = "   Schedule:", AutoSize = true, Padding = new Padding(8, 4, 0, 0) });
        modeRow.Controls.Add(_rbWholeWeek);
        modeRow.Controls.Add(_rbSplit);
        editor.Controls.Add(modeRow);
        editor.Controls.Add(new Label { Text = "Day-part weights (multipliers on base rate)", AutoSize = true });
        editor.Controls.Add(_gridWeights);
        editor.Controls.Add(new Label { Text = "Action rates", AutoSize = true });
        editor.Controls.Add(_gridRates);
        var freqRow = new FlowLayoutPanel { AutoSize = true };
        freqRow.Controls.Add(new Label { Text = "Batch frequency:", AutoSize = true, Padding = new Padding(0, 6, 0, 0) });
        freqRow.Controls.Add(_numFreqCount);
        freqRow.Controls.Add(new Label { Text = "per", AutoSize = true, Padding = new Padding(4, 6, 0, 0) });
        freqRow.Controls.Add(_cmbFreqUnit);
        editor.Controls.Add(freqRow);
        var localeRow = new FlowLayoutPanel { AutoSize = true };

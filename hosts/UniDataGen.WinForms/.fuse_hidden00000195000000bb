using DataGen.Abstractions;

namespace DataGen.WinForms;

/// <summary>
/// A deterministic, network-free value provider for local dry runs. Fills semantic fields with type-shaped
/// placeholders so the pipeline can be exercised without calling Foundry. Swap for FoundryValueProvider in production.
/// </summary>
public sealed class OfflineValueProvider : IValueProvider
{
    private readonly string _industry;

    public OfflineValueProvider(string industry) => _industry = industry;

    public Task<IReadOnlyList<IReadOnlyDictionary<string, object?>>> GenerateAsync(ValueRequest request, CancellationToken cancellationToken)
    {
        var rows = new List<IReadOnlyDictionary<string, object?>>(request.Count);
        for (int i = 0; i < request.Count; i++)
        {
            var row = new Dictionary<string, object?>(StringComparer.Ordinal);
            foreach (AttributeInfo a in request.SemanticAttributes)
            {
                row[a.Name] = Placeholder(a, i);
            }

            rows.Add(row);
        }

        return Task.FromResult<IReadOnlyList<IReadOnlyDictionary<string, object?>>>(rows);
    }

    private object? Placeholder(AttributeInfo a, int i) => a.DataType.ToLowerInvariant() switch
    {
        "integer" or "biginteger" => (long)i,
        "decimal" or "currency" or "amountcur" or "amountmst" => Math.Round(10m + i * 1.5m, 2),
        "boolean" or "noyesid" => i % 2 == 0,
        "datetime" or "transdate" or "date" => DateTimeOffset.UtcNow,
        _ => $"{_industry}:{a.Name}:{i}"
    };
}

using DataGen.Abstractions;

namespace DataGen.WinForms;

/// <summary>Mutable UI state for one selected entity. Converts to the immutable <see cref="EntityProfile"/> on save or run.</summary>
public sealed class EntityProfileVm
{
    public required string SchemaArea { get; init; }
    public required string EntityName { get; init; }
    public string Key => $"{SchemaArea}/{EntityName}";

    public GenerationMode Mode { get; set; } = GenerationMode.Batch;
    public ScheduleSplit Split { get; set; } = ScheduleSplit.WholeWeek;

    // Day-part weights. Week is used for WholeWeek; Weekday/Weekend for the split.
    public double[] Week { get; set; } = [1.0, 1.0, 1.0, 0.3];      // Morning, Afternoon, Evening, Night
    public double[] Weekday { get; set; } = [1.0, 1.4, 0.8, 0.1];
    public double[] Weekend { get; set; } = [0.6, 0.9, 1.2, 0.2];

    // Real-time per-hour rates and batch per-batch rates, each New/Update/Delete.
    public double[] RealtimePerHour { get; set; } = [120, 40, 5];
    public double[] BatchPerBatch { get; set; } = [5000, 1500, 100];
    public int BatchFrequencyCount { get; set; } = 4;
    public BatchUnit BatchFrequencyUnit { get; set; } = BatchUnit.Day;

    public string? TimeZoneId { get; set; }

    /// <summary>BCP-47 locale override for generated values. Null inherits the run-level locale.</summary>
    public string? Locale { get; set; }

    public List<BoostDate> Boosts { get; } = [];

    private static DayPartWeights Weights(double[] w) => new(w[0], w[1], w[2], w[3]);

    /// <summary>Builds the immutable profile for the engine.</summary>
    public EntityProfile ToProfile()
    {
        EntitySchedule schedule = Split == ScheduleSplit.WholeWeek
            ? new EntitySchedule(ScheduleSplit.WholeWeek, Week: Weights(Week))
            : new EntitySchedule(ScheduleSplit.WeekdayWeekend, Weekday: Weights(Weekday), Weekend: Weights(Weekend));

        return new EntityProfile
        {
            SchemaArea = SchemaArea,
            EntityName = EntityName,
            Mode = Mode,
            Schedule = schedule,
            Realtime = Mode == GenerationMode.RealTime
                ? new RealtimeSettings(new ActionRates(RealtimePerHour[0], RealtimePerHour[1], RealtimePerHour[2]))
                : null,
            Batch = Mode == GenerationMode.Batch
                ? new BatchSettings(
                    new BatchFrequency(BatchFrequencyCount, BatchFrequencyUnit),
                    new ActionRates(BatchPerBatch[0], BatchPerBatch[1], BatchPerBatch[2]))
                : null,
            Boosts = [.. Boosts],
            TimeZoneId = TimeZoneId
        };
    }
}

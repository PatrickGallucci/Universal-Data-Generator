<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <!-- WinForms requires the Windows desktop framework; this host builds and runs on Windows only. -->
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AssemblyName>UniDataGen.ConfigEditor</AssemblyName>
    <RootNamespace>UniDataGen.ConfigEditor</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\UniDataGen.Abstractions\UniDataGen.Abstractions.csproj" />
    <ProjectReference Include="..\..\src\UniDataGen.Configuration\UniDataGen.Configuration.csproj" />
  </ItemGroup>
</Project>

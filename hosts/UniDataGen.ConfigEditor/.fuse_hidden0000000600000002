using System.Diagnostics;
using DataGen.Abstractions;
using DataGen.ConfigEditor.AppData;
using DataGen.ConfigEditor.Models;
using DataGen.Configuration;

namespace DataGen.ConfigEditor;

/// <summary>
/// The configuration editor. A property grid edits the full core configuration model: the run header, every
/// entity profile, and every target. Files load and save as run-configuration JSON; the editor's own reference
/// lists and preferences live in local JSON files managed by <see cref="AppDataStore"/>.
/// </summary>
public sealed class MainForm : Form
{
    private readonly PropertyGrid _grid = new() { Dock = DockStyle.Fill, PropertySort = PropertySort.Categorized, HelpVisible = true };
    private readonly ToolStripStatusLabel _fileLabel = new("New configuration") { Spring = true, TextAlign = ContentAlignment.MiddleLeft };
    private readonly ToolStripStatusLabel _folderLabel = new();
    private readonly RunConfigurationLoader _loader = new();

    private ConfigEditModel _model = new();
    private string? _currentPath;

    public MainForm()
    {
        Text = "DataGen Configuration Editor";
        Width = AppDataStore.Instance.Settings.WindowWidth;
        Height = AppDataStore.Instance.Settings.WindowHeight;
        StartPosition = FormStartPosition.CenterScreen;

        BuildMenu();
        Controls.Add(_grid);
        BuildStatusBar();

        _grid.SelectedObject = _model;
        _folderLabel.Text = AppDataStore.Instance.Directory;
        FormClosing += (_, _) => PersistSettings();
    }

    private void BuildMenu()
    {
        var menu = new MenuStrip();

        var file = new ToolStripMenuItem("&File");
        file.DropDownItems.Add(new ToolStripMenuItem("&New", null, (_, _) => NewConfig()) { ShortcutKeys = Keys.Control | Keys.N });
        file.DropDownItems.Add(new ToolStripMenuItem("&Open...", null, (_, _) => OpenConfig()) { ShortcutKeys = Keys.Control | Keys.O });
        file.DropDownItems.Add(new ToolStripMenuItem("&Save", null, (_, _) => SaveConfig()) { ShortcutKeys = Keys.Control | Keys.S });
        file.DropDownItems.Add(new ToolStripMenuItem("Save &As...", null, (_, _) => SaveConfigAs()));
        file.DropDownItems.Add(new ToolStripSeparator());
        file.DropDownItems.Add(new ToolStripMenuItem("Open &data folder", null, (_, _) => OpenDataFolder()));
        file.DropDownItems.Add(new ToolStripSeparator());
        file.DropDownItems.Add(new ToolStripMenuItem("E&xit", null, (_, _) => Close()));

        var edit = new ToolStripMenuItem("&Edit");
        edit.DropDownItems.Add(new ToolStripMenuItem("Add &entity", null, (_, _) => AddEntity()));
        edit.DropDownItems.Add(new ToolStripMenuItem("Add &target", null, (_, _) => AddTarget()));

        var tools = new ToolStripMenuItem("&Tools");
        tools.DropDownItems.Add(new ToolStripMenuItem("&Validate", null, (_, _) => Validate()));

        var help = new ToolStripMenuItem("&Help");
        help.DropDownItems.Add(new ToolStripMenuItem("&About", null, (_, _) => ShowAbout()));

        menu.Items.AddRange([file, edit, tools, help]);
        MainMenuStrip = menu;
        Controls.Add(menu);
    }

    private void BuildStatusBar()
    {
        var status = new StatusStrip();
        status.Items.Add(_fileLabel);
        status.Items.Add(new ToolStripStatusLabel("Data:"));
        status.Items.Add(_folderLabel);
        Controls.Add(status);
    }

    private void NewConfig()
    {
        _model = new ConfigEditModel();
        _currentPath = null;
        Rebind();
        _fileLabel.Text = "New configuration";
    }

    private void OpenConfig()
    {
        using var dialog = new OpenFileDialog { Filter = "Run configuration (*.json)|*.json|All files (*.*)|*.*" };
        if (dialog.ShowDialog(this) != DialogResult.OK)
        {
            return;
        }

        try
        {
            RunConfiguration config = _loader.LoadFromFile(dialog.FileName);
            _model = ConfigMapper.ToEditModel(config);
            _currentPath = dialog.FileName;
            Rebind();
            RememberFile(dialog.FileName);
            _fileLabel.Text = dialog.FileName;
        }
        catch (Exception ex)
        {
            MessageBox.Show(this, ex.Message, "Open failed", MessageBoxButtons.OK, MessageBoxIcon.Error);
        }
    }

    private void SaveConfig()
    {
        if (_currentPath is null)
        {
            SaveConfigAs();
            return;
        }

        WriteTo(_currentPath);
    }

    private void SaveConfigAs()
    {
        using var dialog = new SaveFileDialog { Filter = "Run configuration (*.json)|*.json", FileName = "run-config.json" };
        if (dialog.ShowDialog(this) != DialogResult.OK)
        {
            return;
        }

        _currentPath = dialog.FileName;
        WriteTo(dialog.FileName);
    }

    private void WriteTo(string path)
    {
        try
        {
            RunConfiguration config = ConfigMapper.ToRunConfiguration(_model);
            File.WriteAllText(path, _loader.ToJson(config));
            RememberFile(path);
            _fileLabel.Text = path;
        }
        catch (Exception ex)
        {
            MessageBox.Show(this, ex.Message, "Save failed", MessageBoxButtons.OK, MessageBoxIcon.Error);
        }
    }

    private void AddEntity()
    {
        _model.Entities.Add(new EntityEditModel { EntityName = "NewEntity" });
        _grid.Refresh();
    }

    private void AddTarget()
    {
        _model.Targets.Add(new TargetEditModel { Name = "new-target" });
        _grid.Refresh();
    }

    private void Validate()
    {
        var errors = new List<string>();
        if (string.IsNullOrWhiteSpace(_model.Run.Industry))
        {
            errors.Add("Run industry is empty.");
        }

        if (string.IsNullOrWhiteSpace(_model.Run.SourceType))
        {
            errors.Add("Run source type is empty.");
        }

        if (!string.IsNullOrWhiteSpace(_model.Run.Industry) && !ReferenceCatalog.HasIndustry(_model.Run.Industry))
        {
            errors.Add($"Run industry '{_model.Run.Industry}' is not in the industries catalog.");
        }

        if (!LocaleCatalog.IsSupported(_model.Run.Locale))
        {
            errors.Add($"Run locale '{_model.Run.Locale}' is not in the locale catalog.");
        }

        foreach (EntityEditModel entity in _model.Entities)
        {
            if (!string.IsNullOrWhiteSpace(entity.Locale) && !LocaleCatalog.IsSupported(entity.Locale!))
            {
                errors.Add($"Entity '{entity.SchemaArea}/{entity.EntityName}' has an unsupported locale '{entity.Locale}'.");
            }
        }

        if (_model.Entities.Count == 0)
        {
            errors.Add("No entities are defined.");
        }

        if (_model.Targets.All(t => !t.Enabled))
        {
            errors.Add("No targets are enabled.");
        }

        string message = errors.Count == 0 ? "Configuration looks valid." : string.Join(Environment.NewLine, errors);
        MessageBoxIcon icon = errors.Count == 0 ? MessageBoxIcon.Information : MessageBoxIcon.Warning;
        MessageBox.Show(this, message, "Validation", MessageBoxButtons.OK, icon);
    }

    private void OpenDataFolder()
        => Process.Start(new ProcessStartInfo(AppDataStore.Instance.Directory) { UseShellExecute = true });

    private void ShowAbout()
        => MessageBox.Show(
            this,
            $"DataGen Configuration Editor{Environment.NewLine}Edits the core run configuration.{Environment.NewLine}{Environment.NewLine}Local data: {AppDataStore.Instance.Directory}",
            "About",
            MessageBoxButtons.OK,
            MessageBoxIcon.Information);

    private void Rebind()
    {
        _grid.SelectedObject = _model;
        _grid.Refresh();
    }

    private void RememberFile(string path)
    {
        AppSettings settings = AppDataStore.Instance.Settings;
        settings.LastFilePath = path;
        settings.RecentFiles.Remove(path);
        settings.RecentFiles.Insert(0, path);
        if (settings.RecentFiles.Count > 10)
        {
            settings.RecentFiles.RemoveRange(10, settings.RecentFiles.Count - 10);
        }
    }

    private void PersistSettings()
    {
        AppSettings settings = AppDataStore.Instance.Settings;
        settings.WindowWidth = Width;
        settings.WindowHeight = Height;
        AppDataStore.Instance.SaveSettings();
    }
}

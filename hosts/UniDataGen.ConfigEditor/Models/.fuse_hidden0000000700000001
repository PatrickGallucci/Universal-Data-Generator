using System.ComponentModel;
using DataGen.Abstractions;

namespace DataGen.ConfigEditor.Models;

/// <summary>Editable view of the Foundry settings.</summary>
[TypeConverter(typeof(ExpandableObjectConverter))]
public sealed class FoundryEditModel
{
    [Description("The Azure AI Foundry endpoint.")]
    public string Endpoint { get; set; } = string.Empty;

    [Description("The model deployment name.")]
    public string Deployment { get; set; } = "gpt-4.1";

    [TypeConverter(typeof(AuthMethodConverter))]
    [Description("How the provider authenticates to Foundry.")]
    public string AuthMethod { get; set; } = "ManagedIdentity";

    [Description("Optional Key Vault reference for an API key.")]
    public string? ApiKeySecretRef { get; set; }

    public override string ToString() => Deployment;
}

/// <summary>Editable view of the run header.</summary>
[TypeConverter(typeof(ExpandableObjectConverter))]
public sealed class RunHeaderEditModel
{
    [Description("The industry vertical, matching the catalog Industry sheet.")]
    public string Industry { get; set; } = string.Empty;

    [TypeConverter(typeof(SourceTypeConverter))]
    [Description("The source-system type code.")]
    public string SourceType { get; set; } = string.Empty;

    [TypeConverter(typeof(LocaleConverter))]
    [Description("The default output locale for generated values, for example en-US.")]
    public string Locale { get; set; } = "en-US";

    [TypeConverter(typeof(TimeZoneConverter))]
    [Description("The default time zone used to resolve day parts.")]
    public string? DefaultTimeZoneId { get; set; }

    [Description("The Foundry model deployment settings.")]
    public FoundryEditModel Foundry { get; set; } = new();

    public override string ToString() => $"{Industry} / {SourceType}";
}

/// <summary>Editable day-part multipliers.</summary>
[TypeConverter(typeof(ExpandableObjectConverter))]
public sealed class DayPartWeightsEditModel
{
    public double Morning { get; set; } = 1.0;
    public double Afternoon { get; set; } = 1.0;
    public double Evening { get; set; } = 1.0;
    public double Night { get; set; } = 0.3;

    public override string ToString() => $"M{Morning} A{Afternoon} E{Evening} N{Night}";
}

/// <summary>Editable schedule: the split and the day-part weight sets.</summary>
[TypeConverter(typeof(ExpandableObjectConverter))]
public sealed class ScheduleEditModel
{
    public ScheduleSplit Split { get; set; } = ScheduleSplit.WholeWeek;
    public DayPartWeightsEditModel Week { get; set; } = new();
    public DayPartWeightsEditModel Weekday { get; set; } = new();
    public DayPartWeightsEditModel Weekend { get; set; } = new();

    public override string ToString() => Split.ToString();
}

/// <summary>Editable per-action rates, used for both real-time per hour and batch per batch.</summary>
[TypeConverter(typeof(ExpandableObjectConverter))]
public sealed class ActionRatesEditModel
{
    public double New { get; set; }
    public double Update { get; set; }
    public double Delete { get; set; }

    public override string ToString() => $"N{New} U{Update} D{Delete}";
}

/// <summary>Editable batch cadence.</summary>
[TypeConverter(typeof(ExpandableObjectConverter))]
public sealed class BatchFrequencyEditModel
{
    public int Count { get; set; } = 1;
    public BatchUnit Per { get; set; } = BatchUnit.Day;

    public override string ToString() => $"{Count} per {Per}";
}

/// <summary>Editable boost date.</summary>
public sealed class BoostEditModel
{
    [Description("The peak day, yyyy-MM-dd.")]
    public string Date { get; set; } = DateTime.UtcNow.ToString("yyyy-MM-dd");
    public double BoostPercent { get; set; } = 25;
    public int DaysBefore { get; set; } = 7;
    public int DaysAfter { get; set; } = 7;
    public double BoostPercentOnDate { get; set; } = 50;

    public override string ToString() => $"{Date} ({BoostPercent}%, peak {BoostPercentOnDate}%)";
}

/// <summary>Editable per-entity generation profile.</summary>
[TypeConverter(typeof(ExpandableObjectConverter))]
public sealed class EntityEditModel
{
    public string SchemaArea { get; set; } = "core";
    public string EntityName { get; set; } = string.Empty;
    public GenerationMode Mode { get; set; } = GenerationMode.Batch;

    [TypeConverter(typeof(LocaleConverter))]
    [Description("Overrides the run locale for this entity. Blank inherits the run locale.")]
    public string? Locale { get; set; }

    [TypeConverter(typeof(TimeZoneConverter))]
    public string? TimeZoneId { get; set; }

    public ScheduleEditModel Schedule { get; set; } = new();

    [DisplayName("Realtime per hour")]
    [Description("Records per hour per action when Mode is RealTime.")]
    public ActionRatesEditModel RealtimePerHour { get; set; } = new() { New = 60, Update = 10, Delete = 1 };

    [DisplayName("Batch frequency")]
    public BatchFrequencyEditModel BatchFrequency { get; set; } = new();

    [DisplayName("Batch per batch")]
    [Description("Records per batch per action when Mode is Batch.")]
    public ActionRatesEditModel BatchPerBatch { get; set; } = new() { New = 1000, Update = 100, Delete = 10 };

    public BindingList<BoostEditModel> Boosts { get; set; } = [];

    public override string ToString() => $"{SchemaArea}/{EntityName} ({Mode})";
}

/// <summary>A single target property name and value.</summary>
public sealed class TargetPropertyEditModel
{
    public string Name { get; set; } = string.Empty;
    public string? Value { get; set; }

    public override string ToString() => $"{Name} = {Value}";
}

/// <summary>Editable target configuration.</summary>
[TypeConverter(typeof(ExpandableObjectConverter))]
public sealed class TargetEditModel
{
    [TypeConverter(typeof(TargetTypeConverter))]
    public string TargetType { get; set; } = "JsonFile";

    public string Name { get; set; } = string.Empty;
    public bool Enabled { get; set; } = true;

    [TypeConverter(typeof(AuthMethodConverter))]
    public string AuthMethod { get; set; } = "ManagedIdentity";

    public string? KeyVaultSecretRef { get; set; }

    public BindingList<TargetPropertyEditModel> Properties { get; set; } = [];

    public override string ToString() => $"{TargetType}: {Name}";
}

/// <summary>The full editable configuration bound to the property grid.</summary>
[TypeConverter(typeof(ExpandableObjectConverter))]
public sealed class ConfigEditModel
{
    [Category("Run")]
    public RunHeaderEditModel Run { get; set; } = new();

    [Category("Entities")]
    public BindingList<EntityEditModel> Entities { get; set; } = [];

    [Category("Targets")]
    public BindingList<TargetEditModel> Targets { get; set; } = [];

    public override string ToString() => $"{Entities.Count} entities, {Targets.Count} targets";
}

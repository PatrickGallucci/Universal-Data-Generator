using System.ComponentModel;
using DataGen.ConfigEditor.AppData;

namespace DataGen.ConfigEditor.Models;

/// <summary>Offers the locales from the local catalog as a dropdown, while still allowing a custom value.</summary>
public sealed class LocaleConverter : StringConverter
{
    public override bool GetStandardValuesSupported(ITypeDescriptorContext? context) => true;
    public override bool GetStandardValuesExclusive(ITypeDescriptorContext? context) => false;
    public override StandardValuesCollection GetStandardValues(ITypeDescriptorContext? context)
        => new(AppDataStore.Instance.Locales.Select(l => l.Locale).ToArray());
}


using System.Management.Automation;
using DataGen.Abstractions;
using DataGen.Configuration;
using DataGen.Core;
using DataGen.Generation.Foundry;
using DataGen.Observability;
using DataGen.Targets;
using Microsoft.Extensions.Logging;

namespace DataGen.PowerShell;

/// <summary>Writes the embedded <see cref="Catalog"/> to the pipeline.</summary>
/// <example>
///   <code>$catalog = Import-DataGenCatalog</code>
/// </example>
[Cmdlet(VerbsData.Import, "DataGenCatalog")]
[OutputType(typeof(Catalog))]
public sealed class ImportDataGenCatalogCommand : PSCmdlet
{
    protected override void ProcessRecord() => WriteObject(CatalogStore.Load());
}

/// <summary>
/// Runs a data generation configuration against the engine until the cmdlet is stopped (Ctrl-C). The catalog is
/// embedded in the configuration; only the run configuration is supplied. Use -Offline for a network-free dry run.
/// Logs from every tier flow to Application Insights when APPLICATIONINSIGHTS_CONNECTION_STRING (or
/// -AppInsightsConnectionString) is set.
/// </summary>
/// <example>
///   <code>Start-DataGenRun -ConfigPath .\run-config.json -Offline</code>
/// </example>
[Cmdlet(VerbsLifecycle.Start, "DataGenRun")]
public sealed class StartDataGenRunCommand : PSCmdlet
{
    private readonly CancellationTokenSource _cts = new();

    [Parameter(Mandatory = true)]
    public string ConfigPath { get; set; } = string.Empty;

    [Parameter]
    public int TickSeconds { get; set; } = 2;

    [Parameter]
    public SwitchParameter Offline { get; set; }

    [Parameter]
    public string? AppInsightsConnectionString { get; set; }

    protected override void ProcessRecord()
    {
        using ILoggerFactory loggerFactory = AppInsightsLogging.CreateFactory(AppInsightsConnectionString);

        Catalog catalog = CatalogStore.Load();
        RunConfiguration config = new RunConfigurationLoader().LoadFromFile(GetUnresolvedProviderPathFromPSPath(ConfigPath));

        ValidationResult validation = new RunConfigurationValidator(loggerFactory.CreateLogger<RunConfigurationValidator>())
            .Validate(config, catalog);
        if (!validation.IsValid)
        {
            foreach (string error in validation.Errors)
            {
                WriteWarning(error);
            }

            ThrowTerminatingError(new ErrorRecord(
                new InvalidOperationException("Run configuration is not valid."),
                "InvalidRunConfiguration", ErrorCategory.InvalidData, config));
            return;
        }

        IValueProvider provider = Offline.IsPresent
            ? new EchoValueProvider()
            : new FoundryValueProvider(config.Run.Foundry, logger: loggerFactory.CreateLogger<FoundryValueProvider>());

        var orchestrator = new GenerationOrchestrator(catalog, provider, new SinkFactory(loggerFactory), loggerFactory);
        WriteVerbose("Starting run. Stop with Ctrl-C. Logs flow to Application Insights when configured.");

        orchestrator.RunAsync(config, TimeSpan.FromSeconds(TickSeconds), _cts.Token).GetAwaiter().GetResult();
    }

    protected override void StopProcessing() => _cts.Cancel();

    private sealed class EchoValueProvider : IValueProvider
    {
        public Task<IReadOnlyList<IReadOnlyDictionary<string, object?>>> GenerateAsync(ValueRequest request, CancellationToken cancellationToken)
        {
            var rows = new List<IReadOnlyDictionary<string, object?>>(request.Count);
            for (int i = 0; i < request.Count; i++)
            {
                var row = new Dictionary<string, object?>(StringComparer.Ordinal);
                foreach (AttributeInfo a in request.SemanticAttributes)
                {
                    row[a.Name] = $"{request.Industry}:{a.Name}:{i}";
                }

                rows.Add(row);
            }

            return Task.FromResult<IReadOnlyList<IReadOnlyDictionary<string, object?>>>(rows);
        }
    }
}

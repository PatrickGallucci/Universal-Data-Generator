using DataGen.Foundry.Tool;
using DataGen.Observability;
using Microsoft.Extensions.Logging;

// Command-line shape mirrors the agent tool function so the same entry point serves both.
// Usage: DataGen.Foundry.Tool <configPath> [--offline] [--seconds N]
// Application Insights is used when APPLICATIONINSIGHTS_CONNECTION_STRING is set; console logging is always on.
if (args.Length < 1)
{
    Console.WriteLine("Usage: DataGen.Foundry.Tool <configPath> [--offline] [--seconds N]");
    return 1;
}

bool offline = args.Contains("--offline", StringComparer.OrdinalIgnoreCase);
int seconds = 30;
int idx = Array.FindIndex(args, a => string.Equals(a, "--seconds", StringComparison.OrdinalIgnoreCase));
if (idx >= 0 && idx + 1 < args.Length && int.TryParse(args[idx + 1], out int parsed))
{
    seconds = parsed;
}

using ILoggerFactory loggerFactory = AppInsightsLogging.CreateFactory(
    minimumLevel: LogLevel.Information,
    configure: b => b.AddSimpleConsole(o => o.SingleLine = true));

using var cts = new CancellationTokenSource();
Console.CancelKeyPress += (_, e) => { e.Cancel = true; cts.Cancel(); };

var tool = new GeneratorTool(loggerFactory);
string result = await tool.StartRunAsync(args[0], offline, TimeSpan.FromSeconds(seconds), cts.Token);
Console.WriteLine(result);
return 0;
